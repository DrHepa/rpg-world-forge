*.gltf text eol=lf
*.ldtk text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.lock text eol=lf
*.in text eol=lf
*.tmpl text eol=lf
*.md text eol=lf
*.rst text eol=lf
