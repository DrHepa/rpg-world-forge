{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/asset-production-request.schema.json",
  "title": "Executable GPT-orchestrated asset-production request v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "format_version", "id", "asset_id", "specification", "target_id", "target_hash", "orchestrator", "route", "executor", "operation", "inputs", "parameters", "expected_outputs", "parent_receipt_hashes", "content_hash"],
  "properties": {
    "format": {"const": "rpg-world-forge.asset_production_request"},
    "format_version": {"const": 1},
    "id": {"$ref": "#/$defs/id"},
    "asset_id": {"$ref": "#/$defs/id"},
    "specification": {"$ref": "#/$defs/file_ref"},
    "target_id": {"$ref": "#/$defs/id"},
    "target_hash": {"$ref": "#/$defs/sha256"},
    "orchestrator": {"const": "gpt"},
    "route": {"enum": ["modly", "openai"]},
    "executor": {"$ref": "#/$defs/executor"},
    "operation": {"$ref": "#/$defs/operation"},
    "inputs": {"type": "array", "maxItems": 256, "items": {"$ref": "#/$defs/input"}},
    "parameters": {"type": "object", "maxProperties": 256},
    "expected_outputs": {"type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true, "items": {"$ref": "#/$defs/expected_output"}},
    "parent_receipt_hashes": {"type": "array", "maxItems": 256, "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}},
    "reviewed_script": {"$ref": "#/$defs/python_file_ref"},
    "approval_mode": {"const": "explicit"},
    "content_hash": {"$ref": "#/$defs/sha256"}
  },
  "allOf": [
    {
      "if": {"properties": {"executor": {"const": "openai_image"}}, "required": ["executor"]},
      "then": {"properties": {"route": {"const": "openai"}, "operation": {"enum": ["concept_reference", "image_edit", "image_generate"]}, "reviewed_script": false, "approval_mode": false}}
    },
    {
      "if": {"properties": {"executor": {"const": "blender_mcp"}}, "required": ["executor"]},
      "then": {"required": ["reviewed_script", "approval_mode"], "properties": {"route": {"enum": ["modly", "openai"]}, "operation": {"enum": ["animate", "collision", "export_glb", "material_bake", "model_from_reference", "refine", "retopology", "rig", "uv_unwrap"]}, "inputs": {"type": "array", "minItems": 1}, "parent_receipt_hashes": {"type": "array", "minItems": 1}, "reviewed_script": {"$ref": "#/$defs/python_file_ref"}, "approval_mode": {"const": "explicit"}}}
    },
    {
      "if": {"properties": {"executor": {"const": "modly_cli_mcp"}}, "required": ["executor"]},
      "then": {"properties": {"route": {"const": "modly"}, "operation": {"enum": ["capability_execute", "process_run", "workflow_run"]}, "parameters": {"$ref": "#/$defs/modly_parameters"}, "reviewed_script": false, "approval_mode": false}}
    },
    {
      "if": {"properties": {"executor": {"enum": ["human", "procedural"]}}, "required": ["executor"]},
      "then": {"properties": {"reviewed_script": false, "approval_mode": false}}
    },
    {
      "if": {"properties": {"operation": {"enum": ["image_edit", "image_generate"]}}, "required": ["operation"]},
      "then": {"properties": {"expected_outputs": {"type": "array", "items": {"type": "object", "properties": {"role": {"enum": ["preview", "texture"]}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"operation": {"const": "concept_reference"}}, "required": ["operation"]},
      "then": {"properties": {"expected_outputs": {"type": "array", "items": {"type": "object", "properties": {"role": {"const": "preview"}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"operation": {"const": "model_from_reference"}}, "required": ["operation"]},
      "then": {"properties": {"expected_outputs": {"type": "array", "items": {"type": "object", "properties": {"role": {"enum": ["authoring_source", "model", "preview"]}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"operation": {"enum": ["retopology", "uv_unwrap"]}}, "required": ["operation"]},
      "then": {"properties": {"expected_outputs": {"type": "array", "items": {"type": "object", "properties": {"role": {"enum": ["authoring_source", "model"]}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"operation": {"const": "material_bake"}}, "required": ["operation"]},
      "then": {"properties": {"expected_outputs": {"type": "array", "items": {"type": "object", "properties": {"role": {"enum": ["authoring_source", "material_metadata", "model", "texture"]}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"operation": {"const": "rig"}}, "required": ["operation"]},
      "then": {"properties": {"expected_outputs": {"type": "array", "items": {"type": "object", "properties": {"role": {"enum": ["authoring_source", "model", "skeleton"]}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"operation": {"const": "animate"}}, "required": ["operation"]},
      "then": {"properties": {"expected_outputs": {"type": "array", "items": {"type": "object", "properties": {"role": {"enum": ["animation", "authoring_source", "model"]}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"operation": {"const": "collision"}}, "required": ["operation"]},
      "then": {"properties": {"expected_outputs": {"type": "array", "items": {"type": "object", "properties": {"role": {"enum": ["authoring_source", "collision", "model"]}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"operation": {"const": "export_glb"}}, "required": ["operation"]},
      "then": {"properties": {"expected_outputs": {"type": "array", "items": {"type": "object", "properties": {"role": {"enum": ["animation", "authoring_source", "collision", "model", "skeleton"]}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"operation": {"const": "refine"}}, "required": ["operation"]},
      "then": {"properties": {"expected_outputs": {"type": "array", "items": {"type": "object", "properties": {"role": {"enum": ["animation", "authoring_source", "collision", "material_metadata", "model", "skeleton", "texture"]}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"executor": {"const": "blender_mcp"}, "operation": {"const": "model_from_reference"}}, "required": ["executor", "operation"]},
      "then": {"properties": {"route": {"const": "openai"}, "inputs": {"type": "array", "contains": {"type": "object", "properties": {"role": {"const": "reference"}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"executor": {"const": "blender_mcp"}, "operation": {"enum": ["collision", "export_glb", "material_bake", "refine", "retopology", "rig", "uv_unwrap"]}}, "required": ["executor", "operation"]},
      "then": {"properties": {"inputs": {"type": "array", "contains": {"type": "object", "properties": {"role": {"const": "model"}}, "required": ["role"]}}}}
    },
    {
      "if": {"properties": {"executor": {"const": "blender_mcp"}, "operation": {"const": "animate"}}, "required": ["executor", "operation"]},
      "then": {"properties": {"inputs": {"type": "array", "allOf": [{"type": "array", "contains": {"type": "object", "properties": {"role": {"const": "model"}}, "required": ["role"]}}, {"type": "array", "contains": {"type": "object", "properties": {"role": {"const": "skeleton"}}, "required": ["role"]}}]}}}
    },
    {
      "if": {"properties": {"executor": {"const": "modly_cli_mcp"}, "operation": {"const": "process_run"}}, "required": ["executor", "operation"]},
      "then": {"properties": {"parameters": {"type": "object", "properties": {"canonical_surface": {"const": "process_run"}}, "required": ["canonical_surface"]}}}
    },
    {
      "if": {"properties": {"executor": {"const": "modly_cli_mcp"}, "operation": {"const": "workflow_run"}}, "required": ["executor", "operation"]},
      "then": {"properties": {"parameters": {"type": "object", "properties": {"canonical_surface": {"const": "workflow_run"}}, "required": ["canonical_surface"]}}}
    },
    {
      "if": {
        "properties": {
          "executor": {"const": "openai_image"},
          "parameters": {
            "type": "object",
            "properties": {
              "background": {"const": "transparent"},
              "model": {"type": "string", "pattern": "^gpt-image-2"}
            },
            "required": ["background", "model"]
          }
        },
        "required": ["executor", "parameters"]
      },
      "then": false
    }
  ],
  "$defs": {
    "id": {"type": "string", "pattern": "^(?!(?:aux|con|nul|prn|com[1-9]|lpt[1-9])$)[a-z][a-z0-9_]{1,63}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "project_path": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!/)(?!.*//)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))[^<>:\"\\\\|?*\\u0000-\\u001F/]+(?:/[^<>:\"\\\\|?*\\u0000-\\u001F/]+)*$"},
    "file_ref": {"type": "object", "additionalProperties": false, "required": ["file", "sha256"], "properties": {"file": {"$ref": "#/$defs/project_path"}, "sha256": {"$ref": "#/$defs/sha256"}, "size": {"type": "integer", "minimum": 0, "maximum": 2147483648}}},
    "python_file_ref": {"allOf": [{"$ref": "#/$defs/file_ref"}, {"type": "object", "properties": {"file": {"type": "string", "pattern": "\\.[Pp][Yy]$"}}}]},
    "input": {"type": "object", "additionalProperties": false, "required": ["role", "file", "sha256"], "properties": {"role": {"type": "string", "minLength": 1, "maxLength": 128}, "file": {"$ref": "#/$defs/project_path"}, "sha256": {"$ref": "#/$defs/sha256"}, "size": {"type": "integer", "minimum": 0, "maximum": 2147483648}}},
    "modly_extension": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "revision", "manifest_hash", "workflow_hash"],
      "properties": {"id": {"type": "string", "minLength": 1, "maxLength": 256}, "version": {"type": "string", "minLength": 1, "maxLength": 128}, "revision": {"type": "string", "minLength": 1, "maxLength": 256}, "manifest_hash": {"$ref": "#/$defs/sha256"}, "workflow_hash": {"$ref": "#/$defs/sha256"}}
    },
    "modly_model": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "weights_hash"],
      "properties": {"id": {"type": "string", "minLength": 1, "maxLength": 256}, "version": {"type": "string", "minLength": 1, "maxLength": 128}, "weights_hash": {"$ref": "#/$defs/sha256"}}
    },
    "modly_parameters": {
      "type": "object", "additionalProperties": false,
      "required": ["modly_cli_mcp_version", "modly_version", "canonical_surface", "capability_id", "support_state", "capability_discovery", "extension", "model", "setup_reviewed", "arguments"],
      "properties": {
        "modly_cli_mcp_version": {"type": "string", "minLength": 1, "maxLength": 128},
        "modly_version": {"type": "string", "minLength": 1, "maxLength": 128},
        "canonical_surface": {"enum": ["process_run", "workflow_run"]},
        "capability_id": {"type": "string", "minLength": 1, "maxLength": 512},
        "support_state": {"const": "supported"},
        "capability_discovery": {"$ref": "#/$defs/file_ref"},
        "extension": {"$ref": "#/$defs/modly_extension"},
        "model": {"$ref": "#/$defs/modly_model"},
        "setup_reviewed": {"const": true},
        "arguments": {"type": "object", "maxProperties": 256}
      }
    },
    "executor": {"enum": ["blender_mcp", "human", "modly_cli_mcp", "openai_image", "procedural"]},
    "operation": {"enum": ["animate", "capability_execute", "collision", "concept_reference", "export_glb", "image_edit", "image_generate", "material_bake", "model_from_reference", "process_run", "refine", "retopology", "rig", "uv_unwrap", "workflow_run"]},
    "output_role": {"enum": ["animation", "audio", "authoring_source", "clipset", "collision", "font", "fragment_shader", "material_metadata", "model", "model_metadata", "preview", "skeleton", "texture", "vertex_shader"]},
    "media_type": {"enum": ["application/json", "application/x-blender", "audio/mpeg", "audio/ogg", "audio/wav", "font/otf", "font/ttf", "image/jpeg", "image/png", "image/webp", "model/gltf-binary", "text/x-glsl"]},
    "expected_output": {
      "type": "object", "additionalProperties": false,
      "required": ["role", "media_type"],
      "properties": {"role": {"$ref": "#/$defs/output_role"}, "media_type": {"$ref": "#/$defs/media_type"}},
      "allOf": [
        {"if": {"properties": {"role": {"enum": ["animation", "collision", "model", "skeleton"]}}, "required": ["role"]}, "then": {"properties": {"media_type": {"const": "model/gltf-binary"}}}},
        {"if": {"properties": {"role": {"const": "authoring_source"}}, "required": ["role"]}, "then": {"properties": {"media_type": {"const": "application/x-blender"}}}},
        {"if": {"properties": {"role": {"enum": ["clipset", "material_metadata", "model_metadata"]}}, "required": ["role"]}, "then": {"properties": {"media_type": {"const": "application/json"}}}},
        {"if": {"properties": {"role": {"const": "audio"}}, "required": ["role"]}, "then": {"properties": {"media_type": {"enum": ["audio/mpeg", "audio/ogg", "audio/wav"]}}}},
        {"if": {"properties": {"role": {"const": "font"}}, "required": ["role"]}, "then": {"properties": {"media_type": {"enum": ["font/otf", "font/ttf"]}}}},
        {"if": {"properties": {"role": {"enum": ["fragment_shader", "vertex_shader"]}}, "required": ["role"]}, "then": {"properties": {"media_type": {"const": "text/x-glsl"}}}},
        {"if": {"properties": {"role": {"enum": ["preview", "texture"]}}, "required": ["role"]}, "then": {"properties": {"media_type": {"enum": ["image/jpeg", "image/png", "image/webp"]}}}}
      ]
    }
  }
}
