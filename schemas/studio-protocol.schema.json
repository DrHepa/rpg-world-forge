{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/studio-protocol.schema.json",
  "title": "Forge Studio NDJSON application protocol v1",
  "type": "object",
  "required": ["protocol", "protocol_version", "kind", "request_id"],
  "properties": {
    "protocol": {"const": "rpg-world-forge.studio_protocol"},
    "protocol_version": {"const": 1},
    "kind": {"enum": ["request", "response", "error", "event"]},
    "request_id": {"type": ["string", "null"], "minLength": 1}
  },
  "oneOf": [
    {"$ref": "#/$defs/request"},
    {"$ref": "#/$defs/response"},
    {"$ref": "#/$defs/error"},
    {"$ref": "#/$defs/event"}
  ],
  "$defs": {
    "base": {
      "type": "object",
      "required": ["protocol", "protocol_version", "kind", "request_id"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"enum": ["request", "response", "error", "event"]},
        "request_id": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "method": {
      "enum": [
        "service.initialize",
        "workspace.register",
        "workspace.list",
        "workspace.get",
        "workspace.overview",
        "source.list",
        "source.read",
        "asset.catalog.list",
        "asset.catalog.inspect",
        "world.validate",
        "world.analyze",
        "events.list",
        "changeset.create",
        "changeset.get",
        "changeset.list",
        "changeset.diff",
        "changeset.approve",
        "changeset.reject",
        "changeset.apply",
        "job.create",
        "job.get",
        "job.list",
        "job.transition",
        "job.cancel"
      ]
    },
    "legacyMethod": {
      "enum": [
        "service.initialize",
        "workspace.register",
        "workspace.list",
        "workspace.get",
        "events.list",
        "job.get",
        "job.list",
        "job.transition"
      ]
    },
    "workspaceScopedAuthoringMethod": {
      "enum": ["workspace.overview", "source.list", "world.validate", "world.analyze"]
    },
    "workspaceId": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$"},
    "entityId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "portableSourcePath": {
      "type": "string",
      "format": "rpg-world-forge-portable-source-path",
      "x-worldforge-path-policy": {
        "root": "source/",
        "separator": "/",
        "normalization": "NFC",
        "reject_traversal_segments": true,
        "reject_windows_reserved_names": true,
        "reject_trailing_dot_or_space": true,
        "max_component_utf8_bytes": 255,
        "max_depth": 8,
        "collision_key": "NFC-casefold"
      },
      "pattern": "^source/[^/\\\\\\u0000-\\u001f<>:\\u0022|?*]+(?:/[^/\\\\\\u0000-\\u001f<>:\\u0022|?*]+)*$"
    },
    "workspaceScopedParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id"],
      "properties": {"workspace_id": {"$ref": "#/$defs/workspaceId"}}
    },
    "sourceReadParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id", "path"],
      "properties": {
        "workspace_id": {"$ref": "#/$defs/workspaceId"},
        "path": {"$ref": "#/$defs/portableSourcePath"}
      }
    },
    "assetEntryId": {
      "type": "string",
      "pattern": "^asset_[0-9a-f]{64}$"
    },
    "portableAssetCatalogPath": {
      "type": "string",
      "format": "rpg-world-forge-portable-asset-catalog-path",
      "maxLength": 4096,
      "x-worldforge-path-policy": {
        "root": "registered world root",
        "separator": "/",
        "normalization": "NFC",
        "reject_traversal_segments": true,
        "reject_windows_reserved_names": true,
        "reject_trailing_dot_or_space": true,
        "max_component_utf8_bytes": 255,
        "max_depth": 32,
        "collision_key": "NFC-casefold"
      },
      "pattern": "^[^/\\\\\\u0000-\\u001f<>:\\u0022|?*]+(?:/[^/\\\\\\u0000-\\u001f<>:\\u0022|?*]+)*$"
    },
    "assetCatalogListParams": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["workspace_id"],
          "properties": {
            "workspace_id": {"$ref": "#/$defs/workspaceId"},
            "offset": {"const": 0},
            "limit": {"type": "integer", "minimum": 1, "maximum": 64},
            "expected_manifest_revision": {"$ref": "#/$defs/sha256"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["workspace_id", "offset", "expected_manifest_revision"],
          "properties": {
            "workspace_id": {"$ref": "#/$defs/workspaceId"},
            "offset": {"type": "integer", "minimum": 1},
            "limit": {"type": "integer", "minimum": 1, "maximum": 64},
            "expected_manifest_revision": {"$ref": "#/$defs/sha256"}
          }
        }
      ]
    },
    "assetCatalogInspectParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id", "entry_id", "expected_manifest_revision"],
      "properties": {
        "workspace_id": {"$ref": "#/$defs/workspaceId"},
        "entry_id": {"$ref": "#/$defs/assetEntryId"},
        "expected_manifest_revision": {"$ref": "#/$defs/sha256"}
      }
    },
    "assetCatalogEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "asset_id",
        "category",
        "role",
        "path",
        "sha256",
        "media_type",
        "selected",
        "inspectable"
      ],
      "properties": {
        "entry_id": {"$ref": "#/$defs/assetEntryId"},
        "asset_id": {"type": ["string", "null"], "maxLength": 128},
        "category": {
          "enum": [
            "manifest",
            "target",
            "visual_bible",
            "audio_bible",
            "inventory",
            "specification",
            "production_receipt",
            "production_request",
            "production_output",
            "processing_receipt",
            "processing_recipe",
            "processing_output",
            "license",
            "qa",
            "runtime_output"
          ]
        },
        "role": {"type": ["string", "null"], "maxLength": 128},
        "path": {
          "oneOf": [
            {"$ref": "#/$defs/portableAssetCatalogPath"},
            {"type": "null"}
          ]
        },
        "sha256": {"$ref": "#/$defs/sha256"},
        "media_type": {"type": ["string", "null"], "maxLength": 128},
        "selected": {"type": "boolean"},
        "inspectable": {"type": "boolean"}
      },
      "allOf": [
        {
          "if": {"properties": {"path": {"type": "null"}}},
          "then": {
            "properties": {
              "category": {"const": "processing_recipe"},
              "selected": {"const": false},
              "inspectable": {"const": false}
            }
          }
        },
        {
          "if": {"properties": {"selected": {"const": true}}},
          "then": {"properties": {"category": {"const": "production_output"}}}
        }
      ]
    },
    "assetJsonInspection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "encoding", "content", "value"],
      "properties": {
        "kind": {"const": "json"},
        "encoding": {"const": "utf-8"},
        "content": {
          "type": "string",
          "maxLength": 262144,
          "x-worldforge-max-utf8-bytes": 262144
        },
        "value": {"type": "object"}
      }
    },
    "assetGlslInspection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "encoding", "content"],
      "properties": {
        "kind": {"const": "glsl"},
        "encoding": {"const": "utf-8"},
        "content": {
          "type": "string",
          "maxLength": 262144,
          "x-worldforge-max-utf8-bytes": 262144
        }
      }
    },
    "assetPngInspection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "width", "height", "bit_depth", "color_type", "interlaced"],
      "properties": {
        "kind": {"const": "png"},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "bit_depth": {"type": "integer", "minimum": 1},
        "color_type": {"type": "integer", "minimum": 0},
        "interlaced": {"type": "boolean"}
      }
    },
    "assetWavInspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "channels",
        "sample_rate",
        "sample_width_bits",
        "frame_count",
        "duration_ms"
      ],
      "properties": {
        "kind": {"const": "wav"},
        "channels": {"type": "integer", "minimum": 1},
        "sample_rate": {"type": "integer", "minimum": 1},
        "sample_width_bits": {"type": "integer", "minimum": 1},
        "frame_count": {"type": "integer", "minimum": 0},
        "duration_ms": {"type": "integer", "minimum": 0}
      }
    },
    "assetFontInspection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "flavor", "table_count"],
      "properties": {
        "kind": {"const": "font"},
        "flavor": {"enum": ["truetype", "opentype"]},
        "table_count": {"type": "integer", "minimum": 1}
      }
    },
    "assetGlbMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodes",
        "meshes",
        "materials",
        "textures",
        "skins",
        "bones",
        "influences",
        "animations",
        "vertices",
        "triangles",
        "external_uris"
      ],
      "properties": {
        "nodes": {"type": "integer", "minimum": 0},
        "meshes": {"type": "integer", "minimum": 0},
        "materials": {"type": "integer", "minimum": 0},
        "textures": {"type": "integer", "minimum": 0},
        "skins": {"type": "integer", "minimum": 0},
        "bones": {"type": "integer", "minimum": 0},
        "influences": {"type": "integer", "minimum": 0},
        "animations": {"type": "integer", "minimum": 0},
        "vertices": {"type": "integer", "minimum": 0},
        "triangles": {"type": "integer", "minimum": 0},
        "external_uris": {"type": "integer", "minimum": 0}
      }
    },
    "assetGlbInspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "byte_length",
        "json_chunk_bytes",
        "bin_chunk_bytes",
        "extensions_used",
        "extensions_required",
        "external_uris",
        "embedded_uris",
        "max_texture_dimension",
        "metrics"
      ],
      "properties": {
        "kind": {"const": "glb"},
        "byte_length": {"type": "integer", "minimum": 0},
        "json_chunk_bytes": {"type": "integer", "minimum": 0},
        "bin_chunk_bytes": {"type": "integer", "minimum": 0},
        "extensions_used": {
          "type": "array",
          "maxItems": 64,
          "items": {"type": "string", "maxLength": 256}
        },
        "extensions_required": {
          "type": "array",
          "maxItems": 64,
          "items": {"type": "string", "maxLength": 256}
        },
        "external_uris": {
          "type": "array",
          "maxItems": 64,
          "items": {"type": "string", "maxLength": 256}
        },
        "embedded_uris": {"type": "integer", "minimum": 0},
        "max_texture_dimension": {"type": "integer", "minimum": 0},
        "metrics": {"$ref": "#/$defs/assetGlbMetrics"}
      }
    },
    "assetUnavailableInspection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reason"],
      "properties": {
        "kind": {"const": "unavailable"},
        "reason": {"enum": ["identity_only", "unsupported_media_type"]}
      }
    },
    "assetInspection": {
      "oneOf": [
        {"$ref": "#/$defs/assetJsonInspection"},
        {"$ref": "#/$defs/assetGlslInspection"},
        {"$ref": "#/$defs/assetPngInspection"},
        {"$ref": "#/$defs/assetWavInspection"},
        {"$ref": "#/$defs/assetFontInspection"},
        {"$ref": "#/$defs/assetGlbInspection"},
        {"$ref": "#/$defs/assetUnavailableInspection"}
      ]
    },
    "assetCatalogListResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_revision", "offset", "limit", "entries", "next_offset"],
      "properties": {
        "manifest_revision": {"$ref": "#/$defs/sha256"},
        "offset": {"type": "integer", "minimum": 0},
        "limit": {"type": "integer", "minimum": 1, "maximum": 64},
        "entries": {
          "type": "array",
          "maxItems": 64,
          "items": {"$ref": "#/$defs/assetCatalogEntry"}
        },
        "next_offset": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "assetCatalogInspectResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_revision", "entry", "inspection"],
      "properties": {
        "manifest_revision": {"$ref": "#/$defs/sha256"},
        "entry": {"$ref": "#/$defs/assetCatalogEntry"},
        "inspection": {"$ref": "#/$defs/assetInspection"}
      }
    },
    "sourceDocumentSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "size", "sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/portableSourcePath"},
        "kind": {"type": "string", "minLength": 1, "maxLength": 128},
        "size": {"type": "integer", "minimum": 0, "maximum": 262144},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "sourceDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "size", "sha256", "encoding", "content", "json"],
      "properties": {
        "path": {"$ref": "#/$defs/portableSourcePath"},
        "kind": {"type": "string", "minLength": 1, "maxLength": 128},
        "size": {"type": "integer", "minimum": 0, "maximum": 262144},
        "sha256": {"$ref": "#/$defs/sha256"},
        "encoding": {"const": "utf-8"},
        "content": {"type": "string"},
        "json": {"type": "object"}
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "code", "path", "message"],
      "properties": {
        "severity": {"const": "error"},
        "code": {"enum": ["source_error", "validation_error"]},
        "path": {"type": "string"},
        "message": {"type": "string", "maxLength": 512}
      }
    },
    "worldValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid",
        "profile",
        "world_id",
        "object_count",
        "diagnostics",
        "diagnostics_truncated"
      ],
      "properties": {
        "valid": {"type": "boolean"},
        "profile": {"const": "release"},
        "world_id": {"type": ["string", "null"]},
        "object_count": {"type": "integer", "minimum": 0},
        "diagnostics": {
          "type": "array",
          "maxItems": 512,
          "items": {"$ref": "#/$defs/diagnostic"}
        },
        "diagnostics_truncated": {"type": "boolean"}
      }
    },
    "workspaceOverview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id", "project", "status", "repositories", "capabilities"],
      "properties": {
        "workspace_id": {"$ref": "#/$defs/workspaceId"},
        "project": {
          "type": "object",
          "additionalProperties": false,
          "required": ["world_id", "title", "world_version"],
          "properties": {
            "world_id": {"type": "string", "minLength": 1},
            "title": {"type": "string", "minLength": 1},
            "world_version": {"type": ["string", "null"]}
          }
        },
        "status": {
          "type": "object",
          "additionalProperties": false,
          "required": ["current_phase", "revision", "canon_locked", "worldpack_hash"],
          "properties": {
            "current_phase": {"type": ["string", "null"]},
            "revision": {"type": "integer", "minimum": 0},
            "canon_locked": {"type": "boolean"},
            "worldpack_hash": {
              "oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
            }
          }
        },
        "repositories": {
          "type": "object",
          "additionalProperties": false,
          "required": ["game_registered", "bundle_registered"],
          "properties": {
            "game_registered": {"type": "boolean"},
            "bundle_registered": {"type": "boolean"}
          }
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "providers",
            "source_inspection",
            "world_validation",
            "narrative_analysis",
            "staged_changesets",
            "asset_catalog_inspection"
          ],
          "properties": {
            "providers": {"const": false},
            "source_inspection": {"const": true},
            "world_validation": {"const": true},
            "narrative_analysis": {"const": true},
            "staged_changesets": {"const": true},
            "asset_catalog_inspection": {"const": true}
          }
        }
      }
    },
    "workspaceOverviewResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overview"],
      "properties": {"overview": {"$ref": "#/$defs/workspaceOverview"}}
    },
    "sourceListResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["documents"],
      "properties": {
        "documents": {
          "type": "array",
          "maxItems": 1024,
          "items": {"$ref": "#/$defs/sourceDocumentSummary"}
        }
      }
    },
    "sourceReadResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document"],
      "properties": {"document": {"$ref": "#/$defs/sourceDocument"}}
    },
    "worldValidateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation"],
      "properties": {"validation": {"$ref": "#/$defs/worldValidation"}}
    },
    "worldAnalyzeResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation", "analysis"],
      "properties": {
        "validation": {"$ref": "#/$defs/worldValidation"},
        "analysis": {
          "oneOf": [{"$ref": "#/$defs/narrativeAnalysis"}, {"type": "null"}]
        }
      }
    },
    "narrativeFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "code", "path", "message"],
      "properties": {
        "severity": {"enum": ["error", "warning", "info"]},
        "code": {"type": "string"},
        "path": {"type": "string"},
        "message": {"type": "string"}
      }
    },
    "narrativeAnalysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "format_version", "world_id", "summary", "findings"],
      "properties": {
        "format": {"const": "rpg-world-forge.narrative_analysis"},
        "format_version": {"const": 1},
        "world_id": {"type": "string"},
        "summary": {"type": "object"},
        "findings": {
          "type": "array",
          "items": {"$ref": "#/$defs/narrativeFinding"}
        }
      }
    },
    "changesetStageCreateOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operation", "content"],
      "properties": {
        "path": {"$ref": "#/$defs/portableSourcePath"},
        "operation": {"const": "create"},
        "content": {
          "type": "string",
          "maxLength": 262144,
          "x-worldforge-max-utf8-bytes": 262144
        }
      }
    },
    "changesetStageReplaceOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operation", "expected_base_sha256", "content"],
      "properties": {
        "path": {"$ref": "#/$defs/portableSourcePath"},
        "operation": {"const": "replace"},
        "expected_base_sha256": {"$ref": "#/$defs/sha256"},
        "content": {
          "type": "string",
          "maxLength": 262144,
          "x-worldforge-max-utf8-bytes": 262144
        }
      }
    },
    "changesetStageDeleteOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operation", "expected_base_sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/portableSourcePath"},
        "operation": {"const": "delete"},
        "expected_base_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "changesetCreateParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id", "operations"],
      "properties": {
        "changeset_id": {"$ref": "#/$defs/entityId"},
        "workspace_id": {"$ref": "#/$defs/workspaceId"},
        "operations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "oneOf": [
              {"$ref": "#/$defs/changesetStageCreateOperation"},
              {"$ref": "#/$defs/changesetStageReplaceOperation"},
              {"$ref": "#/$defs/changesetStageDeleteOperation"}
            ]
          }
        }
      }
    },
    "changesetIdParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changeset_id"],
      "properties": {"changeset_id": {"$ref": "#/$defs/entityId"}}
    },
    "changesetListParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workspace_id": {"$ref": "#/$defs/workspaceId"},
        "status": {"enum": ["staged", "approved", "applying", "rejected", "applied"]},
        "limit": {"type": "integer", "minimum": 1, "maximum": 1000}
      }
    },
    "changesetActionParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changeset_id"],
      "properties": {
        "changeset_id": {"$ref": "#/$defs/entityId"},
        "expected_review_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "changesetTextDiffLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "text"],
      "properties": {
        "kind": {"enum": ["context", "remove", "add"]},
        "text": {"type": "string"}
      }
    },
    "changesetTextHunk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_start", "base_count", "proposed_start", "proposed_count", "lines"],
      "properties": {
        "base_start": {"type": "integer", "minimum": 1},
        "base_count": {"type": "integer", "minimum": 0},
        "proposed_start": {"type": "integer", "minimum": 1},
        "proposed_count": {"type": "integer", "minimum": 0},
        "lines": {
          "type": "array",
          "minItems": 1,
          "maxItems": 40000,
          "items": {"$ref": "#/$defs/changesetTextDiffLine"}
        }
      }
    },
    "changesetJsonPointerChange": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["operation", "pointer", "value"],
          "properties": {
            "operation": {"const": "add"},
            "pointer": {"type": "string"},
            "value": {}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["operation", "pointer", "old_value"],
          "properties": {
            "operation": {"const": "remove"},
            "pointer": {"type": "string"},
            "old_value": {}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["operation", "pointer", "old_value", "value"],
          "properties": {
            "operation": {"const": "replace"},
