{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/studio-protocol.schema.json",
  "title": "Forge Studio NDJSON application protocol v1",
  "type": "object",
  "required": ["protocol", "protocol_version", "kind", "request_id"],
  "properties": {
    "protocol": {"const": "rpg-world-forge.studio_protocol"},
    "protocol_version": {"const": 1},
    "kind": {"enum": ["request", "response", "error", "event"]},
    "request_id": {"type": ["string", "null"], "minLength": 1}
  },
  "oneOf": [
    {"$ref": "#/$defs/request"},
    {"$ref": "#/$defs/response"},
    {"$ref": "#/$defs/error"},
    {"$ref": "#/$defs/event"}
  ],
  "$defs": {
    "base": {
      "type": "object",
      "required": ["protocol", "protocol_version", "kind", "request_id"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"enum": ["request", "response", "error", "event"]},
        "request_id": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "method": {
      "enum": [
        "service.initialize",
        "workspace.register",
        "workspace.list",
        "workspace.get",
        "workspace.overview",
        "source.list",
        "source.read",
        "world.validate",
        "world.analyze",
        "events.list",
        "changeset.create",
        "changeset.get",
        "changeset.list",
        "changeset.diff",
        "changeset.approve",
        "changeset.reject",
        "changeset.apply",
        "job.create",
        "job.get",
        "job.list",
        "job.transition",
        "job.cancel"
      ]
    },
    "legacyMethod": {
      "enum": [
        "service.initialize",
        "workspace.register",
        "workspace.list",
        "workspace.get",
        "events.list",
        "job.get",
        "job.list",
        "job.transition"
      ]
    },
    "workspaceScopedAuthoringMethod": {
      "enum": ["workspace.overview", "source.list", "world.validate", "world.analyze"]
    },
    "workspaceId": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$"},
    "entityId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "portableSourcePath": {
      "type": "string",
      "format": "rpg-world-forge-portable-source-path",
      "x-worldforge-path-policy": {
        "root": "source/",
        "separator": "/",
        "normalization": "NFC",
        "reject_traversal_segments": true,
        "reject_windows_reserved_names": true,
        "reject_trailing_dot_or_space": true,
        "max_component_utf8_bytes": 255,
        "max_depth": 8,
        "collision_key": "NFC-casefold"
      },
      "pattern": "^source/[^/\\\\\\u0000-\\u001f<>:\\u0022|?*]+(?:/[^/\\\\\\u0000-\\u001f<>:\\u0022|?*]+)*$"
    },
    "workspaceScopedParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id"],
      "properties": {"workspace_id": {"$ref": "#/$defs/workspaceId"}}
    },
    "sourceReadParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id", "path"],
      "properties": {
        "workspace_id": {"$ref": "#/$defs/workspaceId"},
        "path": {"$ref": "#/$defs/portableSourcePath"}
      }
    },
    "sourceDocumentSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "size", "sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/portableSourcePath"},
        "kind": {"type": "string", "minLength": 1, "maxLength": 128},
        "size": {"type": "integer", "minimum": 0, "maximum": 262144},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "sourceDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "size", "sha256", "encoding", "content", "json"],
      "properties": {
        "path": {"$ref": "#/$defs/portableSourcePath"},
        "kind": {"type": "string", "minLength": 1, "maxLength": 128},
        "size": {"type": "integer", "minimum": 0, "maximum": 262144},
        "sha256": {"$ref": "#/$defs/sha256"},
        "encoding": {"const": "utf-8"},
        "content": {"type": "string"},
        "json": {"type": "object"}
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "code", "path", "message"],
      "properties": {
        "severity": {"const": "error"},
        "code": {"enum": ["source_error", "validation_error"]},
        "path": {"type": "string"},
        "message": {"type": "string", "maxLength": 512}
      }
    },
    "worldValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid",
        "profile",
        "world_id",
        "object_count",
        "diagnostics",
        "diagnostics_truncated"
      ],
      "properties": {
        "valid": {"type": "boolean"},
        "profile": {"const": "release"},
        "world_id": {"type": ["string", "null"]},
        "object_count": {"type": "integer", "minimum": 0},
        "diagnostics": {
          "type": "array",
          "maxItems": 512,
          "items": {"$ref": "#/$defs/diagnostic"}
        },
        "diagnostics_truncated": {"type": "boolean"}
      }
    },
    "workspaceOverview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id", "project", "status", "repositories", "capabilities"],
      "properties": {
        "workspace_id": {"$ref": "#/$defs/workspaceId"},
        "project": {
          "type": "object",
          "additionalProperties": false,
          "required": ["world_id", "title", "world_version"],
          "properties": {
            "world_id": {"type": "string", "minLength": 1},
            "title": {"type": "string", "minLength": 1},
            "world_version": {"type": ["string", "null"]}
          }
        },
        "status": {
          "type": "object",
          "additionalProperties": false,
          "required": ["current_phase", "revision", "canon_locked", "worldpack_hash"],
          "properties": {
            "current_phase": {"type": ["string", "null"]},
            "revision": {"type": "integer", "minimum": 0},
            "canon_locked": {"type": "boolean"},
            "worldpack_hash": {
              "oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
            }
          }
        },
        "repositories": {
          "type": "object",
          "additionalProperties": false,
          "required": ["game_registered", "bundle_registered"],
          "properties": {
            "game_registered": {"type": "boolean"},
            "bundle_registered": {"type": "boolean"}
          }
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "providers",
            "source_inspection",
            "world_validation",
            "narrative_analysis",
            "staged_changesets"
          ],
          "properties": {
            "providers": {"const": false},
            "source_inspection": {"const": true},
            "world_validation": {"const": true},
            "narrative_analysis": {"const": true},
            "staged_changesets": {"const": true}
          }
        }
      }
    },
    "workspaceOverviewResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overview"],
      "properties": {"overview": {"$ref": "#/$defs/workspaceOverview"}}
    },
    "sourceListResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["documents"],
      "properties": {
        "documents": {
          "type": "array",
          "maxItems": 1024,
          "items": {"$ref": "#/$defs/sourceDocumentSummary"}
        }
      }
    },
    "sourceReadResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document"],
      "properties": {"document": {"$ref": "#/$defs/sourceDocument"}}
    },
    "worldValidateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation"],
      "properties": {"validation": {"$ref": "#/$defs/worldValidation"}}
    },
    "worldAnalyzeResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation", "analysis"],
      "properties": {
        "validation": {"$ref": "#/$defs/worldValidation"},
        "analysis": {
          "oneOf": [{"$ref": "#/$defs/narrativeAnalysis"}, {"type": "null"}]
        }
      }
    },
    "narrativeFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "code", "path", "message"],
      "properties": {
        "severity": {"enum": ["error", "warning", "info"]},
        "code": {"type": "string"},
        "path": {"type": "string"},
        "message": {"type": "string"}
      }
    },
    "narrativeAnalysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "format_version", "world_id", "summary", "findings"],
      "properties": {
        "format": {"const": "rpg-world-forge.narrative_analysis"},
        "format_version": {"const": 1},
        "world_id": {"type": "string"},
        "summary": {"type": "object"},
        "findings": {
          "type": "array",
          "items": {"$ref": "#/$defs/narrativeFinding"}
        }
      }
    },
    "changesetStageCreateOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operation", "content"],
      "properties": {
        "path": {"$ref": "#/$defs/portableSourcePath"},
        "operation": {"const": "create"},
        "content": {
          "type": "string",
          "maxLength": 262144,
          "x-worldforge-max-utf8-bytes": 262144
        }
      }
    },
    "changesetStageReplaceOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operation", "expected_base_sha256", "content"],
      "properties": {
        "path": {"$ref": "#/$defs/portableSourcePath"},
        "operation": {"const": "replace"},
        "expected_base_sha256": {"$ref": "#/$defs/sha256"},
        "content": {
          "type": "string",
          "maxLength": 262144,
          "x-worldforge-max-utf8-bytes": 262144
        }
      }
    },
    "changesetStageDeleteOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operation", "expected_base_sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/portableSourcePath"},
        "operation": {"const": "delete"},
        "expected_base_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "changesetCreateParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id", "operations"],
      "properties": {
        "changeset_id": {"$ref": "#/$defs/entityId"},
        "workspace_id": {"$ref": "#/$defs/workspaceId"},
        "operations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "oneOf": [
              {"$ref": "#/$defs/changesetStageCreateOperation"},
              {"$ref": "#/$defs/changesetStageReplaceOperation"},
              {"$ref": "#/$defs/changesetStageDeleteOperation"}
            ]
          }
        }
      }
    },
    "changesetIdParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changeset_id"],
      "properties": {"changeset_id": {"$ref": "#/$defs/entityId"}}
    },
    "changesetListParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workspace_id": {"$ref": "#/$defs/workspaceId"},
        "status": {"enum": ["staged", "approved", "applying", "rejected", "applied"]},
        "limit": {"type": "integer", "minimum": 1, "maximum": 1000}
      }
    },
    "changesetActionParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changeset_id"],
      "properties": {
        "changeset_id": {"$ref": "#/$defs/entityId"},
        "expected_review_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "changesetTextDiffLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "text"],
      "properties": {
        "kind": {"enum": ["context", "remove", "add"]},
        "text": {"type": "string"}
      }
    },
    "changesetTextHunk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_start", "base_count", "proposed_start", "proposed_count", "lines"],
      "properties": {
        "base_start": {"type": "integer", "minimum": 1},
        "base_count": {"type": "integer", "minimum": 0},
        "proposed_start": {"type": "integer", "minimum": 1},
        "proposed_count": {"type": "integer", "minimum": 0},
        "lines": {
          "type": "array",
          "minItems": 1,
          "maxItems": 40000,
          "items": {"$ref": "#/$defs/changesetTextDiffLine"}
        }
      }
    },
    "changesetJsonPointerChange": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["operation", "pointer", "value"],
          "properties": {
            "operation": {"const": "add"},
            "pointer": {"type": "string"},
            "value": {}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["operation", "pointer", "old_value"],
          "properties": {
            "operation": {"const": "remove"},
            "pointer": {"type": "string"},
            "old_value": {}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["operation", "pointer", "old_value", "value"],
          "properties": {
            "operation": {"const": "replace"},
            "pointer": {"type": "string"},
            "old_value": {},
            "value": {}
          }
        }
      ]
    },
    "changesetDiffOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "operation",
        "base_sha256",
        "base_size",
        "proposed_sha256",
        "size",
        "text_hunks",
        "json_pointer_changes"
      ],
      "properties": {
        "path": {"$ref": "#/$defs/portableSourcePath"},
        "operation": {"enum": ["create", "replace", "delete"]},
        "base_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "base_size": {"type": "integer", "minimum": 0, "maximum": 16777216},
        "proposed_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "size": {"type": "integer", "minimum": 0, "maximum": 16777216},
        "text_hunks": {
          "type": "array",
          "maxItems": 20000,
          "items": {"$ref": "#/$defs/changesetTextHunk"}
        },
        "json_pointer_changes": {
          "oneOf": [
            {
              "type": "array",
              "maxItems": 100000,
              "items": {"$ref": "#/$defs/changesetJsonPointerChange"}
            },
            {"type": "null"}
          ]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"operation": {"const": "create"}}},
          "then": {
            "properties": {
              "base_sha256": {"type": "null"},
              "base_size": {"const": 0},
              "proposed_sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        },
        {
          "if": {"properties": {"operation": {"const": "replace"}}},
          "then": {
            "properties": {
              "base_sha256": {"$ref": "#/$defs/sha256"},
              "proposed_sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        },
        {
          "if": {"properties": {"operation": {"const": "delete"}}},
          "then": {
            "properties": {
              "base_sha256": {"$ref": "#/$defs/sha256"},
              "proposed_sha256": {"type": "null"},
              "size": {"const": 0}
            }
          }
        }
      ]
    },
    "changesetDiff": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "changeset_id",
            "changeset_format_version",
            "available",
            "unavailable_reason",
            "review_sha256",
            "operations"
          ],
          "properties": {
            "changeset_id": {"$ref": "#/$defs/entityId"},
            "changeset_format_version": {"const": 1},
            "available": {"const": false},
            "unavailable_reason": {"const": "legacy_base_bytes_not_retained"},
            "review_sha256": {"type": "null"},
            "operations": {"type": "array", "maxItems": 0}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "changeset_id",
            "changeset_format_version",
            "available",
            "unavailable_reason",
            "review_sha256",
            "operations"
          ],
          "properties": {
            "changeset_id": {"$ref": "#/$defs/entityId"},
            "changeset_format_version": {"const": 2},
            "available": {"const": true},
            "unavailable_reason": {"type": "null"},
            "review_sha256": {"$ref": "#/$defs/sha256"},
            "operations": {
              "type": "array",
              "minItems": 1,
              "maxItems": 256,
              "items": {"$ref": "#/$defs/changesetDiffOperation"}
            }
          }
        }
      ]
    },
    "changesetResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changeset"],
      "properties": {"changeset": {"$ref": "studio-changeset.schema.json"}}
    },
    "changesetListResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changesets"],
      "properties": {
        "changesets": {
          "type": "array",
          "maxItems": 1000,
          "items": {"$ref": "studio-changeset.schema.json"}
        }
      }
    },
    "changesetDiffResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diff"],
      "properties": {"diff": {"$ref": "#/$defs/changesetDiff"}}
    },
    "legacyRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"const": "request"},
        "request_id": {"type": "string", "minLength": 1},
        "method": {"$ref": "#/$defs/legacyMethod"},
        "params": {"type": "object"}
      }
    },
    "workspaceScopedAuthoringRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"const": "request"},
        "request_id": {"type": "string", "minLength": 1},
        "method": {"$ref": "#/$defs/workspaceScopedAuthoringMethod"},
        "params": {"$ref": "#/$defs/workspaceScopedParams"}
      }
    },
    "sourceReadRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"const": "request"},
        "request_id": {"type": "string", "minLength": 1},
        "method": {"const": "source.read"},
        "params": {"$ref": "#/$defs/sourceReadParams"}
      }
    },
    "changesetCreateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"const": "request"},
        "request_id": {"type": "string", "minLength": 1},
        "method": {"const": "changeset.create"},
        "params": {"$ref": "#/$defs/changesetCreateParams"}
      }
    },
    "changesetGetRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"const": "request"},
        "request_id": {"type": "string", "minLength": 1},
        "method": {"const": "changeset.get"},
        "params": {"$ref": "#/$defs/changesetIdParams"}
      }
    },
    "changesetListRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"const": "request"},
        "request_id": {"type": "string", "minLength": 1},
        "method": {"const": "changeset.list"},
        "params": {"$ref": "#/$defs/changesetListParams"}
      }
    },
    "changesetDiffRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"const": "request"},
        "request_id": {"type": "string", "minLength": 1},
        "method": {"const": "changeset.diff"},
        "params": {"$ref": "#/$defs/changesetIdParams"}
      }
    },
    "changesetApproveRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"const": "request"},
        "request_id": {"type": "string", "minLength": 1},
        "method": {"const": "changeset.approve"},
        "params": {"$ref": "#/$defs/changesetActionParams"}
      }
    },
    "changesetRejectRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"const": "request"},
        "request_id": {"type": "string", "minLength": 1},
        "method": {"const": "changeset.reject"},
        "params": {"$ref": "#/$defs/changesetActionParams"}
      }
    },
    "changesetApplyRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"const": "request"},
        "request_id": {"type": "string", "minLength": 1},
        "method": {"const": "changeset.apply"},
        "params": {"$ref": "#/$defs/changesetActionParams"}
      }
    },
    "jobCreateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
        "protocol_version": {"const": 1},
        "kind": {"const": "request"},
        "request_id": {"type": "string", "minLength": 1},
        "method": {"const": "job.create"},
        "params": {"$ref": "studio-job.schema.json#/$defs/jobCreateParams"}
      }
    },
    "jobCancelRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "protocol_version", "kind", "request_id", "method", "params"],
      "properties": {
        "protocol": {"const": "rpg-world-forge.studio_protocol"},
