{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/modly-capability-discovery.schema.json",
  "title": "Sanitized pre-execution Modly capability-discovery snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "format_version", "modly_cli_mcp_version", "modly_version", "canonical_surface", "capability_id", "support_state", "extension", "model", "content_hash"],
  "properties": {
    "format": {"const": "rpg-world-forge.modly_capability_discovery"},
    "format_version": {"const": 1},
    "modly_cli_mcp_version": {"type": "string", "minLength": 1, "maxLength": 128},
    "modly_version": {"type": "string", "minLength": 1, "maxLength": 128},
    "canonical_surface": {"enum": ["process_run", "workflow_run"]},
    "capability_id": {"type": "string", "minLength": 1, "maxLength": 512},
    "support_state": {"const": "supported"},
    "extension": {"$ref": "#/$defs/modly_extension"},
    "model": {"$ref": "#/$defs/modly_model"},
    "content_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "modly_extension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "revision", "manifest_hash", "workflow_hash"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 256},
        "version": {"type": "string", "minLength": 1, "maxLength": 128},
        "revision": {"type": "string", "minLength": 1, "maxLength": 256},
        "manifest_hash": {"$ref": "#/$defs/sha256"},
        "workflow_hash": {"$ref": "#/$defs/sha256"}
      }
    },
    "modly_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "weights_hash"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 256},
        "version": {"type": "string", "minLength": 1, "maxLength": 128},
        "weights_hash": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
