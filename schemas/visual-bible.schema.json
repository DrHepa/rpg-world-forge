{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/visual-bible.schema.json",
  "title": "Executable target-scoped visual bible v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "format_version", "world_id", "world_content_hash", "target_id", "target_hash", "camera", "resolution", "style", "silhouettes", "animation", "ui", "vfx", "acceptance_tests", "approved_by", "content_hash"],
  "properties": {
    "format": {"const": "rpg-world-forge.visual_bible"},
    "format_version": {"const": 1},
    "world_id": {"$ref": "#/$defs/id"},
    "world_content_hash": {"$ref": "#/$defs/sha256"},
    "target_id": {"$ref": "#/$defs/id"},
    "target_hash": {"$ref": "#/$defs/sha256"},
    "camera": {"$ref": "#/$defs/decision"},
    "resolution": {"$ref": "#/$defs/decision"},
    "style": {"$ref": "#/$defs/decision"},
    "silhouettes": {"$ref": "#/$defs/decision"},
    "animation": {"$ref": "#/$defs/decision"},
    "ui": {"$ref": "#/$defs/decision"},
    "vfx": {"$ref": "#/$defs/decision"},
    "acceptance_tests": {"$ref": "#/$defs/test_list"},
    "approved_by": {"type": "string", "minLength": 1, "maxLength": 256},
    "content_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^(?!(?:aux|con|nul|prn|com[1-9]|lpt[1-9])$)[a-z][a-z0-9_]{1,63}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "decision": {"type": "object", "minProperties": 1, "maxProperties": 128},
    "test_list": {"type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 4096}}
  }
}
