{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/studio-changeset.schema.json",
  "title": "Forge Studio reviewable file changeset v2",
  "oneOf": [
    {"$ref": "#/$defs/changesetV1"},
    {"$ref": "#/$defs/changesetV2"}
  ],
  "$defs": {
    "changesetV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "format_version",
        "changeset_id",
        "workspace_id",
        "status",
        "operations",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "format": {"const": "rpg-world-forge.studio_changeset"},
        "format_version": {"const": 1},
        "changeset_id": {"$ref": "#/$defs/entityId"},
        "workspace_id": {"$ref": "#/$defs/workspaceId"},
        "status": {"enum": ["staged", "approved", "applying", "rejected", "applied"]},
        "operations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {"$ref": "#/$defs/operationV1"}
        },
        "created_at": {"$ref": "#/$defs/timestamp"},
        "updated_at": {"$ref": "#/$defs/timestamp"}
      }
    },
    "changesetV2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "format_version",
        "changeset_id",
        "workspace_id",
        "status",
        "operations",
        "review_sha256",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "format": {"const": "rpg-world-forge.studio_changeset"},
        "format_version": {"const": 2},
        "changeset_id": {"$ref": "#/$defs/entityId"},
        "workspace_id": {"$ref": "#/$defs/workspaceId"},
        "status": {"enum": ["staged", "approved", "applying", "rejected", "applied"]},
        "operations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {"$ref": "#/$defs/operation"}
        },
        "review_sha256": {"$ref": "#/$defs/sha256"},
        "created_at": {"$ref": "#/$defs/timestamp"},
        "updated_at": {"$ref": "#/$defs/timestamp"}
      }
    },
    "workspaceId": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$"},
    "entityId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,6})?Z$"
    },
    "sourcePath": {
      "type": "string",
      "format": "rpg-world-forge-portable-source-path",
      "x-worldforge-path-policy": {
        "root": "source/",
        "separator": "/",
        "normalization": "NFC",
        "reject_traversal_segments": true,
        "reject_windows_reserved_names": true,
        "reject_trailing_dot_or_space": true,
        "max_component_utf8_bytes": 255,
        "collision_key": "NFC-casefold"
      },
      "pattern": "^source/[^/\\\\\\u0000-\\u001f<>:\\u0022|?*]+(?:/[^/\\\\\\u0000-\\u001f<>:\\u0022|?*]+)*$"
    },
    "operationV1": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "operation", "base_sha256", "proposed_sha256", "size"],
          "properties": {
            "path": {"$ref": "#/$defs/sourcePath"},
            "operation": {"const": "create"},
            "base_sha256": {"type": "null"},
            "proposed_sha256": {"$ref": "#/$defs/sha256"},
            "size": {"type": "integer", "minimum": 0, "maximum": 16777216}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "operation", "base_sha256", "proposed_sha256", "size"],
          "properties": {
            "path": {"$ref": "#/$defs/sourcePath"},
            "operation": {"const": "replace"},
            "base_sha256": {"$ref": "#/$defs/sha256"},
            "proposed_sha256": {"$ref": "#/$defs/sha256"},
            "size": {"type": "integer", "minimum": 0, "maximum": 16777216}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "operation", "base_sha256", "proposed_sha256", "size"],
          "properties": {
            "path": {"$ref": "#/$defs/sourcePath"},
            "operation": {"const": "delete"},
            "base_sha256": {"$ref": "#/$defs/sha256"},
            "proposed_sha256": {"type": "null"},
            "size": {"const": 0}
          }
        }
      ]
    },
    "operation": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "operation",
            "base_sha256",
            "base_size",
            "proposed_sha256",
            "size"
          ],
          "properties": {
            "path": {"$ref": "#/$defs/sourcePath"},
            "operation": {"const": "create"},
            "base_sha256": {"type": "null"},
            "base_size": {"const": 0},
            "proposed_sha256": {"$ref": "#/$defs/sha256"},
            "size": {"type": "integer", "minimum": 0, "maximum": 16777216}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "operation",
            "base_sha256",
            "base_size",
            "proposed_sha256",
            "size"
          ],
          "properties": {
            "path": {"$ref": "#/$defs/sourcePath"},
            "operation": {"const": "replace"},
            "base_sha256": {"$ref": "#/$defs/sha256"},
            "base_size": {"type": "integer", "minimum": 0, "maximum": 16777216},
            "proposed_sha256": {"$ref": "#/$defs/sha256"},
            "size": {"type": "integer", "minimum": 0, "maximum": 16777216}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "operation",
            "base_sha256",
            "base_size",
            "proposed_sha256",
            "size"
          ],
          "properties": {
            "path": {"$ref": "#/$defs/sourcePath"},
            "operation": {"const": "delete"},
            "base_sha256": {"$ref": "#/$defs/sha256"},
            "base_size": {"type": "integer", "minimum": 0, "maximum": 16777216},
            "proposed_sha256": {"type": "null"},
            "size": {"const": 0}
          }
        }
      ]
    }
  }
}
