{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/asset-license-record.schema.json",
  "title": "Executable release asset-license record v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "format_version", "asset_id", "output_hashes", "components", "notices", "approved_by", "content_hash"],
  "properties": {
    "format": {"const": "rpg-world-forge.asset_license_record"},
    "format_version": {"const": 1},
    "asset_id": {"$ref": "#/$defs/id"},
    "output_hashes": {"type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}},
    "components": {
      "type": "array",
      "minItems": 6,
      "maxItems": 512,
      "items": {"$ref": "#/$defs/component"},
      "allOf": [
        {"contains": {"type": "object", "properties": {"scope": {"const": "asset"}}, "required": ["scope"]}},
        {"contains": {"type": "object", "properties": {"scope": {"const": "source"}}, "required": ["scope"]}},
        {"contains": {"type": "object", "properties": {"scope": {"const": "model"}}, "required": ["scope"]}},
        {"contains": {"type": "object", "properties": {"scope": {"const": "weights"}}, "required": ["scope"]}},
        {"contains": {"type": "object", "properties": {"scope": {"const": "dataset"}}, "required": ["scope"]}},
        {"contains": {"type": "object", "properties": {"scope": {"const": "output"}}, "required": ["scope"]}}
      ]
    },
    "notices": {"$ref": "#/$defs/file_ref"},
    "approved_by": {"type": "string", "minLength": 1, "maxLength": 256},
    "content_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^(?!(?:aux|con|nul|prn|com[1-9]|lpt[1-9])$)[a-z][a-z0-9_]{1,63}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "project_path": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!/)(?!.*//)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))[^<>:\"\\\\|?*\\u0000-\\u001F/]+(?:/[^<>:\"\\\\|?*\\u0000-\\u001F/]+)*$"},
    "file_ref": {"type": "object", "additionalProperties": false, "required": ["file", "sha256"], "properties": {"file": {"$ref": "#/$defs/project_path"}, "sha256": {"$ref": "#/$defs/sha256"}, "size": {"type": "integer", "minimum": 0, "maximum": 2147483648}}},
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "license_expression", "redistribution", "evidence"],
      "properties": {
        "scope": {"enum": ["asset", "dataset", "model", "output", "source", "weights"]},
        "license_expression": {"type": "string", "minLength": 1, "maxLength": 512},
        "redistribution": {"enum": ["notice_required", "permitted", "source_required"]},
        "evidence": {"$ref": "#/$defs/file_ref"}
      }
    }
  }
}
