{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/asset-processing-recipe.schema.json",
  "title": "Executable deterministic asset-processing recipe v1",
  "oneOf": [
    {"$ref": "#/$defs/png_canonical_recipe"},
    {"$ref": "#/$defs/atlas_recipe"},
    {"$ref": "#/$defs/wav_pcm_recipe"},
    {"$ref": "#/$defs/glb_validate_recipe"},
    {"$ref": "#/$defs/file_validate_recipe"}
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "id": {"type": "string", "pattern": "^(?!(?:aux|con|nul|prn|com[1-9]|lpt[1-9])$)[a-z][a-z0-9_]{1,63}$"},
    "project_path": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!/)(?!.*//)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))[^<>:\"\\\\|?*\\u0000-\\u001F/]+(?:/[^<>:\"\\\\|?*\\u0000-\\u001F/]+)*$"},
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "sha256"],
      "properties": {
        "file": {"$ref": "#/$defs/project_path"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size": {"type": "integer", "minimum": 0, "maximum": 2147483648}
      }
    },
    "single_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file"],
      "properties": {"file": {"allOf": [{"$ref": "#/$defs/project_path"}, {"not": {"const": "processing.receipt.json"}}]}}
    },
    "file_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "media_type", "role"],
      "properties": {
        "file": {"allOf": [{"$ref": "#/$defs/project_path"}, {"not": {"const": "processing.receipt.json"}}]},
        "media_type": {"enum": ["font/otf", "font/ttf", "text/x-glsl"]},
        "role": {"enum": ["font", "fragment_shader", "vertex_shader"]}
      },
      "allOf": [
        {
          "if": {"properties": {"media_type": {"const": "font/otf"}}},
          "then": {"properties": {"file": {"type": "string", "pattern": "\\.[Oo][Tt][Ff]$"}, "role": {"const": "font"}}}
        },
        {
          "if": {"properties": {"media_type": {"const": "font/ttf"}}},
          "then": {"properties": {"file": {"type": "string", "pattern": "\\.[Tt][Tt][Ff]$"}, "role": {"const": "font"}}}
        },
        {
          "if": {"properties": {"media_type": {"const": "text/x-glsl"}, "role": {"const": "vertex_shader"}}},
          "then": {"properties": {"file": {"type": "string", "pattern": "\\.(?:[Gg][Ll][Ss][Ll]|[Vv][Ee][Rr][Tt]|[Vv][Ss])$"}}}
        },
        {
          "if": {"properties": {"media_type": {"const": "text/x-glsl"}, "role": {"const": "fragment_shader"}}},
          "then": {"properties": {"file": {"type": "string", "pattern": "\\.(?:[Ff][Rr][Aa][Gg]|[Ff][Ss]|[Gg][Ll][Ss][Ll])$"}}}
        },
        {
          "if": {"properties": {"media_type": {"const": "text/x-glsl"}}},
          "then": {"properties": {"role": {"enum": ["fragment_shader", "vertex_shader"]}}}
        }
      ]
    },
    "rgb": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"type": "integer", "minimum": 0, "maximum": 255}
    },
    "rgba": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"type": "integer", "minimum": 0, "maximum": 255}
    },
    "crop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bottom", "left", "right", "top"],
      "properties": {
        "bottom": {"type": "integer", "minimum": 1, "maximum": 16384},
        "left": {"type": "integer", "minimum": 0, "maximum": 16383},
        "right": {"type": "integer", "minimum": 1, "maximum": 16384},
        "top": {"type": "integer", "minimum": 0, "maximum": 16383}
      }
    },
    "matte_alpha_key": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rgb", "tolerance"],
      "properties": {
        "rgb": {"$ref": "#/$defs/rgb"},
        "tolerance": {"type": "integer", "minimum": 0, "maximum": 255}
      }
    },
    "pad": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bottom", "color", "left", "right", "top"],
      "properties": {
        "bottom": {"type": "integer", "minimum": 0, "maximum": 16384},
        "color": {"$ref": "#/$defs/rgba"},
        "left": {"type": "integer", "minimum": 0, "maximum": 16384},
        "right": {"type": "integer", "minimum": 0, "maximum": 16384},
        "top": {"type": "integer", "minimum": 0, "maximum": 16384}
      }
    },
    "resize": {
      "type": "object",
      "additionalProperties": false,
      "required": ["height", "width"],
      "properties": {
        "height": {"type": "integer", "minimum": 1, "maximum": 16384},
        "width": {"type": "integer", "minimum": 1, "maximum": 16384}
      }
    },
    "png_options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "crop": {"$ref": "#/$defs/crop"},
        "matte_alpha_key": {"$ref": "#/$defs/matte_alpha_key"},
        "pad": {"$ref": "#/$defs/pad"},
        "resize": {"$ref": "#/$defs/resize"}
      }
    },
    "png_canonical_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "format_version", "operation", "input", "output", "options", "content_hash"],
      "properties": {
        "format": {"const": "rpg-world-forge.asset_processing_recipe"},
        "format_version": {"const": 1},
        "operation": {"const": "png_canonical"},
        "input": {"$ref": "#/$defs/artifact_ref"},
        "output": {"allOf": [{"$ref": "#/$defs/single_output"}, {"type": "object", "properties": {"file": {"type": "string", "pattern": "\\.[Pp][Nn][Gg]$"}}}]},
        "options": {"$ref": "#/$defs/png_options"},
        "content_hash": {"$ref": "#/$defs/sha256"}
      }
    },
    "atlas_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "clip_id", "duration_ticks", "id", "loop", "pivot"],
      "properties": {
        "artifact": {"$ref": "#/$defs/artifact_ref"},
        "clip_id": {"$ref": "#/$defs/id"},
        "duration_ticks": {"type": "integer", "minimum": 1, "maximum": 10000},
        "id": {"$ref": "#/$defs/id"},
        "loop": {"type": "boolean"},
        "pivot": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {"type": "integer", "minimum": -16384, "maximum": 16384}
        }
      }
    },
    "atlas_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clipset_file", "texture_file"],
      "properties": {
        "clipset_file": {"allOf": [{"$ref": "#/$defs/project_path"}, {"type": "string", "pattern": "\\.[Jj][Ss][Oo][Nn]$"}, {"not": {"const": "processing.receipt.json"}}]},
        "texture_file": {"allOf": [{"$ref": "#/$defs/project_path"}, {"type": "string", "pattern": "\\.[Pp][Nn][Gg]$"}, {"not": {"const": "processing.receipt.json"}}]}
      }
    },
    "atlas_options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cell_height", "cell_width", "columns"],
      "properties": {
        "cell_height": {"type": "integer", "minimum": 1, "maximum": 16384},
        "cell_width": {"type": "integer", "minimum": 1, "maximum": 16384},
        "columns": {"type": "integer", "minimum": 1, "maximum": 100000}
      }
    },
    "atlas_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "format_version", "operation", "inputs", "output", "options", "content_hash"],
      "properties": {
        "format": {"const": "rpg-world-forge.asset_processing_recipe"},
        "format_version": {"const": 1},
        "operation": {"const": "atlas"},
        "inputs": {"type": "array", "minItems": 1, "maxItems": 100000, "items": {"$ref": "#/$defs/atlas_input"}},
        "output": {"$ref": "#/$defs/atlas_output"},
        "options": {"$ref": "#/$defs/atlas_options"},
        "content_hash": {"$ref": "#/$defs/sha256"}
      }
    },
    "wav_options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_mode", "peak", "sample_rate", "trim_threshold"],
      "properties": {
        "channel_mode": {"enum": ["mono", "stereo"]},
        "peak": {"type": "integer", "minimum": 1, "maximum": 32767},
        "sample_rate": {"type": "integer", "minimum": 1, "maximum": 384000},
        "trim_threshold": {"type": "integer", "minimum": 0, "maximum": 32767}
      }
    },
    "wav_pcm_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "format_version", "operation", "input", "output", "options", "content_hash"],
      "properties": {
        "format": {"const": "rpg-world-forge.asset_processing_recipe"},
        "format_version": {"const": 1},
        "operation": {"const": "wav_pcm"},
        "input": {"$ref": "#/$defs/artifact_ref"},
        "output": {"allOf": [{"$ref": "#/$defs/single_output"}, {"type": "object", "properties": {"file": {"type": "string", "pattern": "\\.[Ww][Aa][Vv]$"}}}]},
        "options": {"$ref": "#/$defs/wav_options"},
        "content_hash": {"$ref": "#/$defs/sha256"}
      }
    },
    "glb_role": {"enum": ["animation", "collision", "model", "skeleton"]},
    "glb_budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_nodes": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "max_meshes": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "max_materials": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "max_textures": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "max_skins": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "max_bones": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "max_influences": {"type": "integer", "minimum": 0, "maximum": 16},
        "max_animations": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "max_vertices": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "max_triangles": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "max_texture_size": {"type": "integer", "minimum": 1, "maximum": 32768},
        "max_external_uris": {"const": 0}
      }
    },
    "glb_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "role"],
      "properties": {
        "file": {"allOf": [{"$ref": "#/$defs/project_path"}, {"type": "string", "pattern": "\\.[Gg][Ll][Bb]$"}, {"not": {"const": "processing.receipt.json"}}]},
        "role": {"$ref": "#/$defs/glb_role"}
      }
    },
    "glb_options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["budgets", "max_bytes"],
      "properties": {
        "budgets": {"$ref": "#/$defs/glb_budgets"},
        "max_bytes": {"type": "integer", "minimum": 1, "maximum": 536870912}
      }
    },
    "glb_validate_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "format_version", "operation", "input", "output", "options", "content_hash"],
      "properties": {
        "format": {"const": "rpg-world-forge.asset_processing_recipe"},
        "format_version": {"const": 1},
        "operation": {"const": "glb_validate"},
        "input": {"$ref": "#/$defs/artifact_ref"},
        "output": {"$ref": "#/$defs/glb_output"},
        "options": {"$ref": "#/$defs/glb_options"},
        "content_hash": {"$ref": "#/$defs/sha256"}
      }
    },
    "file_validate_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "format_version", "operation", "input", "output", "options", "content_hash"],
      "properties": {
        "format": {"const": "rpg-world-forge.asset_processing_recipe"},
        "format_version": {"const": 1},
        "operation": {"const": "file_validate"},
        "input": {"$ref": "#/$defs/artifact_ref"},
        "output": {"$ref": "#/$defs/file_output"},
        "options": {"type": "object", "additionalProperties": false, "maxProperties": 0},
        "content_hash": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
