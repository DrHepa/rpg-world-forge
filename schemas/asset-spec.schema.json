{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/asset-spec.schema.json",
  "title": "Provider-independent asset specification",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "format",
    "format_version",
    "id",
    "kind",
    "purpose",
    "acceptance_criteria",
    "technical"
  ],
  "properties": {
    "format": {"const": "rpg-world-forge.asset_spec"},
    "format_version": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$"},
    "kind": {
      "enum": [
        "font",
        "music",
        "portrait",
        "shader",
        "sfx",
        "sprite",
        "spritesheet",
        "tileset",
        "ui",
        "vfx"
      ]
    },
    "purpose": {"type": "string", "minLength": 1},
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "technical": {
      "type": "object",
      "required": ["runtime_format", "memory_budget_bytes"],
      "properties": {
        "runtime_format": {"type": "string", "minLength": 1},
        "memory_budget_bytes": {"type": "integer", "minimum": 1},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "sample_rate": {"type": "integer", "minimum": 8000, "maximum": 192000},
        "channels": {"enum": [1, 2]}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {"enum": ["portrait", "sprite", "spritesheet", "tileset", "ui", "vfx"]}
        }
      },
      "then": {"properties": {"technical": {"required": ["width", "height"]}}}
    },
    {
      "if": {"properties": {"kind": {"enum": ["music", "sfx"]}}},
      "then": {"properties": {"technical": {"required": ["sample_rate", "channels"]}}}
    }
  ]
}
