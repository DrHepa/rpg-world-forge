{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/asset-inventory.schema.json",
  "title": "Deterministic target-scoped asset inventory v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "format_version",
    "world_id",
    "world_content_hash",
    "target_id",
    "target_hash",
    "visual_bible_hash",
    "audio_bible_hash",
    "requirements",
    "manual_additions",
    "content_hash"
  ],
  "properties": {
    "format": {"const": "rpg-world-forge.asset_inventory"},
    "format_version": {"const": 1},
    "world_id": {"$ref": "#/$defs/id"},
    "world_content_hash": {"$ref": "#/$defs/sha256"},
    "target_id": {"$ref": "#/$defs/id"},
    "target_hash": {"$ref": "#/$defs/sha256"},
    "visual_bible_hash": {"$ref": "#/$defs/sha256"},
    "audio_bible_hash": {"$ref": "#/$defs/sha256"},
    "requirements": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100000,
      "items": {"$ref": "#/$defs/requirement"}
    },
    "manual_additions": {
      "type": "array",
      "maxItems": 100000,
      "items": {"$ref": "#/$defs/requirement"}
    },
    "content_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^(?!(?:aux|con|nul|prn|com[1-9]|lpt[1-9])$)[a-z][a-z0-9_]{1,63}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "kind": {
      "enum": [
        "animation_3d",
        "character_3d",
        "collision_3d",
        "environment_3d",
        "font",
        "material_set",
        "model_3d",
        "music",
        "portrait",
        "rig",
        "sfx",
        "shader",
        "sprite",
        "spritesheet",
        "tileset",
        "ui",
        "vfx",
        "vfx_3d"
      ]
    },
    "representation": {
      "enum": [
        "2d",
        "2_5d",
        "3d",
        "audio"
      ]
    },
    "semantic_slot": {
      "type": "string",
      "minLength": 3,
      "maxLength": 194,
      "pattern": "^[a-z][a-z0-9_]*(?::[a-z][a-z0-9_]*){1,2}$"
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "representation", "required", "purpose", "canonical_sources", "semantic_slots"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {"$ref": "#/$defs/kind"},
        "representation": {"$ref": "#/$defs/representation"},
        "required": {"type": "boolean"},
        "purpose": {"type": "string", "minLength": 1, "maxLength": 4096},
        "canonical_sources": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 256}
        },
        "semantic_slots": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/semantic_slot"}
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"kind": {"enum": ["music", "sfx"]}},
            "required": ["kind"]
          },
          "then": {"properties": {"representation": {"const": "audio"}}}
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "animation_3d",
                  "character_3d",
                  "collision_3d",
                  "environment_3d",
                  "material_set",
                  "model_3d",
                  "rig",
                  "vfx_3d"
                ]
              }
            },
            "required": ["kind"]
          },
          "then": {"properties": {"representation": {"const": "3d"}}}
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": ["font", "portrait", "shader", "sprite", "spritesheet", "tileset", "ui", "vfx"]
              }
            },
            "required": ["kind"]
          },
          "then": {"properties": {"representation": {"enum": ["2d", "2_5d"]}}}
        }
      ]
    }
  }
}
