{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/task-claim.schema.json",
  "title": "RPG World Forge delegated task claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "format_version",
    "task_id",
    "owner",
    "role",
    "status",
    "objective",
    "non_goals",
    "owned_paths",
    "read_inputs",
    "dependencies",
    "validation",
    "handoff_path"
  ],
  "properties": {
    "format": {
      "const": "rpg-world-forge.task_claim"
    },
    "format_version": {
      "const": 1
    },
    "task_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "claimed",
        "blocked",
        "ready_for_integration",
        "integrated",
        "cancelled"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owned_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "read_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "handoff_path": {
      "type": "string",
      "minLength": 1
    }
  }
}
