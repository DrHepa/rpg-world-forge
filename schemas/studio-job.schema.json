{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/studio-job.schema.json",
  "title": "Forge Studio durable job record v2 with v1 read compatibility",
  "type": "object",
  "properties": {
    "format": {
      "const": "rpg-world-forge.studio_job"
    },
    "format_version": {
      "enum": [
        1,
        2
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/legacyJobV1"
    },
    {
      "$ref": "#/$defs/managedJobV2"
    }
  ],
  "$defs": {
    "legacyJobV1": {
      "title": "Legacy Studio job record v1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "format_version",
        "job_id",
        "workspace_id",
        "operation",
        "state",
        "input",
        "result",
        "error",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "format": {
          "const": "rpg-world-forge.studio_job"
        },
        "format_version": {
          "const": 1
        },
        "job_id": {
          "$ref": "#/$defs/jobId"
        },
        "workspace_id": {
          "$ref": "#/$defs/workspaceId"
        },
        "operation": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]{0,127}$"
        },
        "state": {
          "$ref": "#/$defs/jobState"
        },
        "input": {
          "type": "object"
        },
        "result": {
          "type": [
            "object",
            "null"
          ]
        },
        "error": {
          "type": [
            "object",
            "null"
          ]
        },
        "created_at": {
          "$ref": "#/$defs/timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "managedJobV2": {
      "title": "Managed Studio job record v2",
      "allOf": [
        {
          "$ref": "#/$defs/managedJobV2Common"
        },
        {
          "oneOf": [
            {
              "$ref": "#/$defs/assetReceiptValidateOperation"
            },
            {
              "$ref": "#/$defs/assetpackVerifyOperation"
            },
            {
              "$ref": "#/$defs/runtimeHeadlessOperation"
            },
            {
              "$ref": "#/$defs/runtimeReplayOperation"
            }
          ]
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "state": {
                "const": "succeeded"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "type": "object",
            "properties": {
              "result": {
                "not": {
                  "type": "null"
                }
              },
              "error": {
                "type": "null"
              }
            }
          },
          "else": {
            "if": {
              "type": "object",
              "properties": {
                "state": {
                  "const": "failed"
                }
              },
              "required": [
                "state"
              ]
            },
            "then": {
              "type": "object",
              "properties": {
                "result": {
                  "type": "null"
                },
                "error": {
                  "$ref": "#/$defs/jobError"
                }
              }
            },
            "else": {
              "type": "object",
              "properties": {
                "result": {
                  "type": "null"
                },
                "error": {
                  "type": "null"
                }
              }
            }
          }
        }
      ]
    },
    "managedJobV2Common": {
      "title": "Managed Studio job v2 common record",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "format_version",
        "job_id",
        "workspace_id",
        "operation",
        "state",
        "input",
        "result",
        "error",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "format": {
          "const": "rpg-world-forge.studio_job"
        },
        "format_version": {
          "const": 2
        },
        "job_id": {
          "$ref": "#/$defs/jobId"
        },
        "workspace_id": {
          "$ref": "#/$defs/workspaceId"
        },
        "operation": {
          "$ref": "#/$defs/jobOperation"
        },
        "state": {
          "$ref": "#/$defs/jobState"
        },
        "input": {
          "oneOf": [
            {
              "$ref": "#/$defs/assetReceiptValidateInput"
            },
            {
              "$ref": "#/$defs/assetpackVerifyInput"
            },
            {
              "$ref": "#/$defs/runtimeHeadlessInput"
            },
            {
              "$ref": "#/$defs/runtimeReplayInput"
            }
          ]
        },
        "result": {
          "oneOf": [
            {
              "$ref": "#/$defs/assetReceiptValidateResult"
            },
            {
              "$ref": "#/$defs/assetpackVerifyResult"
            },
            {
              "$ref": "#/$defs/runtimeHeadlessResult"
            },
            {
              "$ref": "#/$defs/runtimeReplayResult"
            },
            {
              "type": "null"
            }
          ]
        },
        "error": {
          "oneOf": [
            {
              "$ref": "#/$defs/jobError"
            },
            {
              "type": "null"
            }
          ]
        },
        "created_at": {
          "$ref": "#/$defs/timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "jobId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
    },
    "workspaceId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{1,63}$"
    },
    "jobOperation": {
      "enum": [
        "asset.receipt.validate",
        "assetpack.verify",
        "runtime.headless",
        "runtime.replay"
      ]
    },
    "jobState": {
      "enum": [
        "queued",
        "running",
        "awaiting_approval",
        "awaiting_user",
        "paused",
        "succeeded",
        "failed",
        "canceled",
        "orphaned"
      ]
    },
    "portableRelativePath": {
      "type": "string",
      "format": "rpg-world-forge-portable-relative-path",
      "x-worldforge-path-policy": {
        "separator": "/",
        "normalization": "NFC",
        "reject_traversal_segments": true,
        "reject_windows_reserved_names": true,
        "reject_trailing_dot_or_space": true,
        "max_component_utf8_bytes": 255,
        "max_depth": 16,
        "collision_key": "NFC-casefold"
      }
    },
    "assetReceiptValidateInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt"
      ],
      "properties": {
        "receipt": {
          "$ref": "#/$defs/portableRelativePath"
        }
      }
    },
    "assetpackVerifyInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assetpack",
        "worldpack"
      ],
      "properties": {
        "assetpack": {
          "$ref": "#/$defs/portableRelativePath"
        },
        "worldpack": {
          "$ref": "#/$defs/portableRelativePath"
        }
      }
    },
    "runtimeHeadlessInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worldpack",
        "ticks"
      ],
      "properties": {
        "worldpack": {
          "$ref": "#/$defs/portableRelativePath"
        },
        "ticks": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        }
      }
    },
    "runtimeReplayInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worldpack",
        "replay"
      ],
      "properties": {
        "worldpack": {
          "$ref": "#/$defs/portableRelativePath"
        },
        "replay": {
          "$ref": "#/$defs/portableRelativePath"
        }
      }
    },
    "receiptIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "message"
      ],
      "properties": {
        "path": {
          "type": "string",
          "maxLength": 512
        },
        "message": {
          "type": "string",
          "maxLength": 512
        }
      }
    },
    "assetReceiptValidateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "valid",
        "issue_count",
        "issues_truncated",
        "issues"
      ],
      "properties": {
        "operation": {
          "const": "asset.receipt.validate"
        },
        "valid": {
          "type": "boolean"
        },
        "issue_count": {
          "type": "integer",
          "minimum": 0
        },
        "issues_truncated": {
          "type": "boolean"
        },
        "issues": {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/receiptIssue"
          }
        }
      }
    },
    "assetpackVerifyResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "valid",
        "world_id",
        "world_content_hash",
        "target_id",
        "target_hash",
        "content_hash",
        "asset_count",
        "file_count",
        "binding_count"
      ],
      "properties": {
        "operation": {
          "const": "assetpack.verify"
        },
        "valid": {
          "const": true
        },
        "world_id": {
          "type": "string",
          "minLength": 1
        },
        "world_content_hash": {
          "$ref": "#/$defs/sha256"
        },
        "target_id": {
          "type": "string",
          "minLength": 1
        },
        "target_hash": {
          "$ref": "#/$defs/sha256"
        },
        "content_hash": {
          "$ref": "#/$defs/sha256"
        },
        "asset_count": {
          "type": "integer",
          "minimum": 0
        },
        "file_count": {
          "type": "integer",
          "minimum": 0
        },
        "binding_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "runtimeHeadlessResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "world_id",
        "world_content_hash",
        "ticks",
        "state_tick",
        "absolute_minute",
        "state_digest"
      ],
      "properties": {
        "operation": {
          "const": "runtime.headless"
        },
        "world_id": {
          "type": "string",
          "minLength": 1
        },
        "world_content_hash": {
          "$ref": "#/$defs/sha256"
        },
        "ticks": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "state_tick": {
          "type": "integer",
          "minimum": 0
        },
        "absolute_minute": {
          "type": "integer",
          "minimum": 0
        },
        "state_digest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "runtimeReplayResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "world_id",
        "world_content_hash",
        "action_count",
        "state_tick",
        "absolute_minute",
        "state_digest"
      ],
      "properties": {
        "operation": {
          "const": "runtime.replay"
        },
        "world_id": {
          "type": "string",
          "minLength": 1
        },
        "world_content_hash": {
          "$ref": "#/$defs/sha256"
        },
        "action_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "state_tick": {
          "type": "integer",
          "minimum": 0
        },
        "absolute_minute": {
          "type": "integer",
          "minimum": 0
        },
        "state_digest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "jobError": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "enum": [
            "execution_failed",
            "invalid_workspace",
            "timeout",
            "worker_crashed",
            "worker_protocol"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    },
    "assetReceiptValidateOperation": {
      "type": "object",
      "required": [
        "operation",
        "input",
        "result"
      ],
      "properties": {
        "operation": {
          "const": "asset.receipt.validate"
        },
        "input": {
          "$ref": "#/$defs/assetReceiptValidateInput"
        },
        "result": {
          "oneOf": [
            {
              "$ref": "#/$defs/assetReceiptValidateResult"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "assetpackVerifyOperation": {
      "type": "object",
      "required": [
        "operation",
        "input",
        "result"
      ],
      "properties": {
        "operation": {
          "const": "assetpack.verify"
        },
        "input": {
          "$ref": "#/$defs/assetpackVerifyInput"
        },
        "result": {
          "oneOf": [
            {
              "$ref": "#/$defs/assetpackVerifyResult"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "runtimeHeadlessOperation": {
      "type": "object",
      "required": [
        "operation",
        "input",
        "result"
      ],
      "properties": {
        "operation": {
          "const": "runtime.headless"
        },
        "input": {
          "$ref": "#/$defs/runtimeHeadlessInput"
        },
        "result": {
          "oneOf": [
            {
              "$ref": "#/$defs/runtimeHeadlessResult"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "runtimeReplayOperation": {
      "type": "object",
      "required": [
        "operation",
        "input",
        "result"
      ],
      "properties": {
        "operation": {
          "const": "runtime.replay"
        },
        "input": {
          "$ref": "#/$defs/runtimeReplayInput"
        },
        "result": {
          "oneOf": [
            {
              "$ref": "#/$defs/runtimeReplayResult"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "jobCreateParams": {
      "oneOf": [
        {
          "$ref": "#/$defs/assetReceiptValidateCreateParams"
        },
        {
          "$ref": "#/$defs/assetpackVerifyCreateParams"
        },
        {
          "$ref": "#/$defs/runtimeHeadlessCreateParams"
        },
        {
          "$ref": "#/$defs/runtimeReplayCreateParams"
        }
      ]
    },
    "assetReceiptValidateCreateParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_id",
        "operation",
        "input"
      ],
      "properties": {
        "job_id": {
          "$ref": "#/$defs/jobId"
        },
        "workspace_id": {
          "$ref": "#/$defs/workspaceId"
        },
        "operation": {
          "const": "asset.receipt.validate"
        },
        "input": {
          "$ref": "#/$defs/assetReceiptValidateInput"
        }
      }
    },
    "assetpackVerifyCreateParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_id",
        "operation",
        "input"
      ],
      "properties": {
        "job_id": {
          "$ref": "#/$defs/jobId"
        },
        "workspace_id": {
          "$ref": "#/$defs/workspaceId"
        },
        "operation": {
          "const": "assetpack.verify"
        },
        "input": {
          "$ref": "#/$defs/assetpackVerifyInput"
        }
      }
    },
    "runtimeHeadlessCreateParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_id",
        "operation",
        "input"
      ],
      "properties": {
        "job_id": {
          "$ref": "#/$defs/jobId"
        },
        "workspace_id": {
          "$ref": "#/$defs/workspaceId"
        },
        "operation": {
          "const": "runtime.headless"
        },
        "input": {
          "$ref": "#/$defs/runtimeHeadlessInput"
        }
      }
    },
    "runtimeReplayCreateParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_id",
        "operation",
        "input"
      ],
      "properties": {
        "job_id": {
          "$ref": "#/$defs/jobId"
        },
        "workspace_id": {
          "$ref": "#/$defs/workspaceId"
        },
        "operation": {
          "const": "runtime.replay"
        },
        "input": {
          "$ref": "#/$defs/runtimeReplayInput"
        }
      }
    },
    "jobCancelParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id"
      ],
      "properties": {
        "job_id": {
          "$ref": "#/$defs/jobId"
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,6})?Z$"
    }
  }
}
