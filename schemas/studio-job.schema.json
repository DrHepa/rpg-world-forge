{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/studio-job.schema.json",
  "title": "Forge Studio durable job record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "format_version",
    "job_id",
    "workspace_id",
    "operation",
    "state",
    "input",
    "result",
    "error",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "format": {"const": "rpg-world-forge.studio_job"},
    "format_version": {"const": 1},
    "job_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"},
    "workspace_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$"},
    "operation": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{0,127}$"},
    "state": {
      "enum": [
        "queued",
        "running",
        "awaiting_approval",
        "awaiting_user",
        "paused",
        "succeeded",
        "failed",
        "canceled",
        "orphaned"
      ]
    },
    "input": {"type": "object"},
    "result": {"type": ["object", "null"]},
    "error": {"type": ["object", "null"]},
    "created_at": {"$ref": "#/$defs/timestamp"},
    "updated_at": {"$ref": "#/$defs/timestamp"}
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,6})?Z$"
    }
  }
}
