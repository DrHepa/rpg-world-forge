{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/phase-report.schema.json",
  "title": "RPG World Forge phase report",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*//)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*(?:^|/)(?:[Aa][Uu][Xx]|[Cc][Oo][Nn]|[Nn][Uu][Ll]|[Pp][Rr][Nn]|[Cc][Oo][Mm][1-9]|[Ll][Pp][Tt][1-9])(?:\\.|/|$))(?!.*(?:^|/)[^/]*[ .](?:/|$))[^<>:\"\\\\|?*\\u0000-\\u001F/]+(?:/[^<>:\"\\\\|?*\\u0000-\\u001F/]+)*$",
      "description": "Normalized portable relative POSIX path. Runtime validation also enforces NFC and the 255-byte component limit."
    }
  },
  "required": [
    "format",
    "format_version",
    "phase",
    "status",
    "summary",
    "deliverables",
    "decisions",
    "blockers",
    "validations",
    "reviewed_by"
  ],
  "allOf": [
    {
      "if": {"properties": {"phase": {"const": "p11_art_audio"}}},
      "then": {
        "required": ["asset_target_path", "visual_bible_path", "audio_bible_path"],
        "properties": {
          "asset_target_path": {"$ref": "#/$defs/projectPath"},
          "visual_bible_path": {"$ref": "#/$defs/projectPath"},
          "audio_bible_path": {"$ref": "#/$defs/projectPath"}
        }
      }
    },
    {
      "if": {"properties": {"phase": {"const": "p12_asset_specs"}}},
      "then": {
        "required": ["asset_inventory_path", "asset_manifest_path"],
        "properties": {
          "asset_inventory_path": {"$ref": "#/$defs/projectPath"},
          "asset_manifest_path": {"$ref": "#/$defs/projectPath"}
        }
      }
    },
    {
      "if": {"properties": {"phase": {"const": "p13_asset_production"}}},
      "then": {
        "required": ["asset_manifest_path"],
        "properties": {
          "asset_manifest_path": {"$ref": "#/$defs/projectPath"},
          "renderpack_path": {"$ref": "#/$defs/projectPath"},
          "assetpack_path": {"$ref": "#/$defs/projectPath"}
        },
        "oneOf": [
          {
            "required": ["renderpack_path"],
            "properties": {"renderpack_path": {"$ref": "#/$defs/projectPath"}},
            "not": {
              "required": ["assetpack_path"],
              "properties": {"assetpack_path": {"$ref": "#/$defs/projectPath"}}
            }
          },
          {
            "required": ["assetpack_path"],
            "properties": {"assetpack_path": {"$ref": "#/$defs/projectPath"}},
            "not": {
              "required": ["renderpack_path"],
              "properties": {"renderpack_path": {"$ref": "#/$defs/projectPath"}}
            }
          }
        ]
      }
    }
  ],
  "properties": {
    "format": {
      "const": "rpg-world-forge.phase_report"
    },
    "format_version": {
      "const": 1
    },
    "phase": {
      "type": "string",
      "pattern": "^p[0-9]{2}_[a-z0-9_]+$"
    },
    "status": {
      "const": "ready"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/projectPath"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "maxItems": 0
    },
    "validations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "passed",
          "evidence"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "passed": {
            "const": true
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "reviewed_by": {
      "type": "string",
      "minLength": 1
    },
    "worldpack_path": {
      "$ref": "#/$defs/projectPath"
    },
    "worldpack_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "asset_manifest_path": {
      "$ref": "#/$defs/projectPath"
    },
    "asset_target_path": {
      "$ref": "#/$defs/projectPath"
    },
    "visual_bible_path": {
      "$ref": "#/$defs/projectPath"
    },
    "audio_bible_path": {
      "$ref": "#/$defs/projectPath"
    },
    "asset_inventory_path": {
      "$ref": "#/$defs/projectPath"
    },
    "renderpack_path": {
      "$ref": "#/$defs/projectPath"
    },
    "assetpack_path": {
      "$ref": "#/$defs/projectPath"
    },
    "handoff_path": {
      "$ref": "#/$defs/projectPath"
    }
  }
}
