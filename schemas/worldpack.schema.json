{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://isoworld.local/schemas/worldpack.schema.json",
  "title": "Compiled IsoWorld worldpack",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "format_version", "world", "collections", "content_hash"],
  "properties": {
    "format": {"const": "isoworld.worldpack"},
    "format_version": {"enum": [1, 2, 3]},
    "content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "world": {
      "type": "object",
      "required": ["id", "title", "language", "start_map_id", "ui"]
    },
    "collections": {
      "type": "object",
      "required": ["tile_types", "maps", "actors"],
      "properties": {
        "facts": {
          "type": "array",
          "items": {"$ref": "narrative-content.schema.json#/$defs/fact"}
        },
        "factions": {
          "type": "array",
          "items": {"$ref": "narrative-content.schema.json#/$defs/faction"}
        },
        "dialogues": {
          "type": "array",
          "items": {"$ref": "narrative-content.schema.json#/$defs/dialogue"}
        },
        "quests": {
          "type": "array",
          "items": {"$ref": "narrative-content.schema.json#/$defs/quest"}
        },
        "scenes": {
          "type": "array",
          "items": {"$ref": "narrative-content.schema.json#/$defs/scene"}
        }
      },
      "additionalProperties": {
        "type": "array",
        "items": {"type": "object", "required": ["id"]}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"format_version": {"const": 3}}},
      "then": {
        "properties": {
          "collections": {
            "required": ["facts", "factions", "dialogues", "quests", "scenes"]
          }
        }
      }
    }
  ]
}
