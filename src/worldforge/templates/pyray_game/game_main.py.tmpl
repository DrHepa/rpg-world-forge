from isoworld.render.resources import ResourceError

SLOT_PATTERN = re.compile(r"^[a-z][a-z0-9_-]{0,31}$")


def _absolute_environment_root(name: str, fallback: Path) -> Path:
    raw = os.environ.get(name)
    candidate = Path(raw) if raw else None
    return candidate if candidate is not None and candidate.is_absolute() else fallback


def _default_user_data_root() -> Path:
    home = Path.home()
    if sys.platform == "win32":
        base = _absolute_environment_root("LOCALAPPDATA", home / "AppData/Local")
    elif sys.platform == "darwin":
        base = home / "Library/Application Support"
    else:
        base = _absolute_environment_root("XDG_DATA_HOME", home / ".local/share")
    return (base / GAME_ID).resolve()


def _slot_name(value: str) -> str:
    if SLOT_PATTERN.fullmatch(value) is None:
        raise argparse.ArgumentTypeError(
            "must use lowercase letters, digits, underscore, or hyphen"
        )
    return value


def _nonnegative_ticks(value: str) -> int:
    try:
        ticks = int(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError("must be an integer") from exc
    if ticks < 0:
        raise argparse.ArgumentTypeError("must be zero or greater")
    return ticks


def _slot_path(
    root: Path,
    category: str,
    world_id: str,
    release_id: str,
    slot: str | None,
) -> Path | None:
    if slot is None:
        return None
    if SLOT_PATTERN.fullmatch(slot) is None:
        raise CatalogError("slot names must satisfy the safe slot policy")
    return root / category / world_id / release_id / f"{slot}.json"


def _save_path(
    root: Path,
    world_id: str,
    release_id: str,
    slot: str | None,
) -> Path | None:
    return _slot_path(root, "saves", world_id, release_id, slot)


def _replay_path(
    root: Path,
    world_id: str,
    release_id: str,
    slot: str | None,
) -> Path | None:
    return _slot_path(root, "replays", world_id, release_id, slot)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=f"Run {GAME_TITLE}", allow_abbrev=False)
    parser.add_argument("--world", help="installed world ID")
    parser.add_argument("--release", help="installed release ID")
    parser.add_argument("--profile", help="installed composed presentation profile ID")
    parser.add_argument("--adapter-id", help="installed composed adapter ID")
    parser.add_argument("--adapter-version", help="installed composed adapter version")
    parser.add_argument("--bundle-id", help="installed composed bundle ID")
    parser.add_argument("--bundle-version", help="installed composed bundle version")
    parser.add_argument("--list-worlds", action="store_true", help="list installed releases")
    parser.add_argument(
        "--headless-ticks",
        type=_nonnegative_ticks,
        metavar="N",
        help="simulate N ticks without importing pyray or opening a window",
    )
    parser.add_argument("--load-slot", type=_slot_name, help="load a named save slot")
    parser.add_argument(
        "--quick-save-slot",
        type=_slot_name,
        help="F5/F9 quick-save slot",
    )
    parser.add_argument(
        "--save-on-exit-slot",
        type=_slot_name,
        help="write a named save after the run",
    )
    parser.add_argument(
        "--record-replay-slot",
        type=_slot_name,
        help="record deterministic actions to a named replay slot",
    )
    parser.add_argument(
        "--replay-slot",
        type=_slot_name,
        help="verify and reproduce a named replay slot",
    )
    parser.add_argument(
        "--user-data",
        type=Path,
        default=_default_user_data_root(),
        help="writable settings/save/replay root (defaults to platform user data)",
    )
    return parser


def _parse_args(argv: Sequence[str] | None = None) -> argparse.Namespace:
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.list_worlds and (args.record_replay_slot is not None or args.replay_slot is not None):
        parser.error("--list-worlds cannot be combined with replay execution")
    if args.replay_slot is not None:
        conflicts = [
            flag
            for flag, selected in (
                ("--headless-ticks", args.headless_ticks is not None),
                ("--load-slot", args.load_slot is not None),
                ("--quick-save-slot", args.quick_save_slot is not None),
                ("--save-on-exit-slot", args.save_on_exit_slot is not None),
                ("--record-replay-slot", args.record_replay_slot is not None),
            )
            if selected
        ]
        if conflicts:
            parser.error(f"--replay-slot cannot be combined with {', '.join(conflicts)}")
    if args.record_replay_slot is not None and args.load_slot is not None:
        parser.error("--record-replay-slot cannot be combined with --load-slot")
    composed_values = (
        args.profile,
        args.adapter_id,
        args.adapter_version,
        args.bundle_id,
        args.bundle_version,
    )
    if any(value is not None for value in composed_values):
        if args.world is None or args.release is None or args.profile is None:
            parser.error("composed selection requires --world, --release, and --profile")
        if (args.adapter_id is None) != (args.adapter_version is None):
            parser.error("--adapter-id and --adapter-version must be provided together")
        if (args.bundle_id is None) != (args.bundle_version is None):
            parser.error("--bundle-id and --bundle-version must be provided together")
    return args


def _run_loaded(
    args: argparse.Namespace,
    selected: CatalogRelease | ComposedCatalogRelease,
    pack: WorldPack,
    renderpack: RenderPack | None,
    *,
    composed_native: bool = False,
) -> tuple[int, str]:
    user_data = args.user_data.expanduser().resolve()
    if user_data == PROJECT_ROOT or PROJECT_ROOT in user_data.parents:
        raise CatalogError("--user-data must be outside the installed game tree")
    replay_path = _replay_path(
        user_data,
        selected.world_id,
        selected.release_id,
        args.replay_slot,
    )
    if replay_path is not None:
        actions, state = load_replay(replay_path, pack)
        return (
            0,
            f"world={pack.world_id} release={selected.release_id} "
            f"replay_actions={len(actions)} tick={state.tick} "
            f"digest={state_digest(state)}",
        )
    record_path = _replay_path(
        user_data,
        selected.world_id,
        selected.release_id,
        args.record_replay_slot,
    )
    load_path = _save_path(
        user_data,
        selected.world_id,
        selected.release_id,
        args.load_slot,
    )
    quick_path = _save_path(
        user_data,
        selected.world_id,
        selected.release_id,
        args.quick_save_slot,
    )
    exit_path = _save_path(
        user_data,
        selected.world_id,
        selected.release_id,
        args.save_on_exit_slot,
    )
    initial = load_game(load_path, pack) if load_path is not None else None
    if composed_native:
        if renderpack is None:
            raise Pyray25DError("composed native execution requires a verified renderpack")
        PYRAY_2_5D_ADAPTER.preflight(pack, renderpack)
        app = PYRAY_2_5D_ADAPTER.create_app(
            pack,
            renderpack,
            state=initial,
            quick_save_path=quick_path,
            replay_recording=record_path is not None,
        )
    else:
        app = GameApp(
            pack,
            initial,
            quick_path,
            renderpack,
            replay_recording=record_path is not None,
        )
    if args.headless_ticks is not None:
        state = app.run_headless(args.headless_ticks)
        result = 0
    else:
        result = app.run()
        state = app.simulation.state
    if exit_path is not None:
        save_game(exit_path, state, pack)
    if record_path is not None:
        write_replay(record_path, app.simulation.action_log, state, pack)
    return (
        result,
        f"world={pack.world_id} release={selected.release_id} tick={state.tick} "
        f"day={state.day} minute={state.minute_of_day} "
        f"active_actor={state.active_actor_id} digest={state_digest(state)}",
    )


def _run_with_owned_renderpack(
    args: argparse.Namespace,
    selected: CatalogRelease | ComposedCatalogRelease,
    pack: WorldPack,
    renderpack: RenderPack | None,
    *,
    composed_native: bool = False,
) -> tuple[int, str]:
    if renderpack is None:
        return _run_loaded(
            args,
            selected,
            pack,
            None,
            composed_native=composed_native,
        )
    with renderpack:
        return _run_loaded(
            args,
            selected,
            pack,
            renderpack,
            composed_native=composed_native,
        )


def _error_detail(exc: BaseException) -> str:
    detail = str(exc)
    cleanup = exc.__cause__
    if isinstance(cleanup, ResourceError) and str(cleanup).startswith("Runtime cleanup failed:"):
        detail += f"; {cleanup}"
    for note in getattr(exc, "__notes__", ()):
        if "cleanup failed" in note and note not in detail:
            detail += f"; {note}"
    return detail


def main(arguments: Sequence[str] | None = None) -> int:
    args = _parse_args(arguments)
    try:
        releases = load_catalog()
        composed_releases = load_composed_catalog()
        validate_cross_catalog_world_hashes(releases, composed_releases)
        if args.list_worlds:
            for release in releases:
                features = ",".join(release.required_runtime_features) or "-"
                print(
                    f"world={release.world_id} release={release.release_id} "
                    f"bundle={release.bundle_hash} features={features}"
                )
            for release in composed_releases:
                print(
                    f"world={release.world_id} release={release.release_id} "
                    f"profile={release.profile_id} adapter={release.adapter_id}@"
                    f"{release.adapter_version} bundle={release.bundle_id}@"
                    f"{release.bundle_version}"
                )
            return 0
        if (
            not releases
            and not composed_releases
            and args.headless_ticks == 0
            and args.world is None
            and args.release is None
            and args.load_slot is None
            and args.quick_save_slot is None
            and args.save_on_exit_slot is None
            and args.record_replay_slot is None
            and args.replay_slot is None
        ):
            print("world=- release=- tick=0 status=empty_catalog shell=ready")
            return 0
        if getattr(args, "profile", None) is not None:
            selected_composed = select_composed_release(
                composed_releases,
                world_id=args.world,
                release_id=args.release,
                profile_id=args.profile,
                adapter_id=getattr(args, "adapter_id", None),
                adapter_version=getattr(args, "adapter_version", None),
                bundle_id=getattr(args, "bundle_id", None),
                bundle_version=getattr(args, "bundle_version", None),
            )
            with verify_composed_release(selected_composed) as composed:
                pack = load_worldpack(composed.worldpack_path)
                compatibility = pack.compatibility_with(
                    RUNTIME_API_VERSION,
                    SUPPORTED_RUNTIME_FEATURES,
                )
                if not compatibility.compatible:
                    raise CatalogError("Runtime is incompatible with the selected composed world")
                if args.headless_ticks is None and args.replay_slot is None:
                    if not composed.native_compatible:
                        raise CatalogError(
                            "selected composed release has no compatible native "
                            "presentation adapter"
                        )
                    if composed.renderpack_path is None:
                        raise CatalogError(
                            "selected composed release has no compatible native "
                            "presentation adapter"
                        )
                    composed_renderpack = load_renderpack(composed.renderpack_path, pack)
                else:
                    composed_renderpack = None
                result, success = _run_with_owned_renderpack(
                    args,
                    selected_composed,
                    pack,
                    composed_renderpack,
                    composed_native=composed_renderpack is not None,
                )
            print(success)
            return result
        selected = select_release(
            releases,
            world_id=args.world,
            release_id=args.release,
        )
        bundle = verify_release(selected)
        pack = load_worldpack(bundle.worldpack_path)
        compatibility = pack.compatibility_with(
            RUNTIME_API_VERSION,
            SUPPORTED_RUNTIME_FEATURES,
        )
        if not compatibility.compatible:
            raise CatalogError(
                "Runtime is incompatible with the selected world: "
                f"api_compatible={compatibility.api_compatible}, "
                f"missing_features={list(compatibility.missing_required_features)}"
            )
        if compatibility.missing_optional_features:
            print(
                "WARNING optional runtime features unavailable: "
                + ", ".join(compatibility.missing_optional_features),
                file=sys.stderr,
            )
        renderpack = load_renderpack(bundle.renderpack_path, pack)
        result, success = _run_with_owned_renderpack(args, selected, pack, renderpack)
        print(success)
        return result
    except (
        CatalogError,
        ComposedCatalogError,
        PersistenceError,
        Pyray25DError,
        RenderPackError,
        ResourceError,
        WorldPackError,
    ) as exc:
        print(f"ERROR {_error_detail(exc)}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
