from __future__ import annotations

from pathlib import Path

from isoworld.content.catalog import CatalogError as CatalogError
from isoworld.content.catalog import CatalogRelease, VerifiedBundle
from isoworld.content.catalog import load_catalog as _load_catalog
from isoworld.content.catalog import select_release as select_release
from isoworld.content.catalog import verify_catalog as _verify_catalog
from isoworld.content.catalog import verify_release as _verify_release

PROJECT_ROOT = Path(__file__).resolve().parents[2]


def load_catalog(project_root: str | Path | None = None) -> tuple[CatalogRelease, ...]:
    return _load_catalog(PROJECT_ROOT if project_root is None else project_root)


def verify_release(
    release: CatalogRelease,
    project_root: str | Path | None = None,
) -> VerifiedBundle:
    return _verify_release(
        release,
        PROJECT_ROOT if project_root is None else project_root,
    )


def verify_catalog(
    project_root: str | Path | None = None,
) -> tuple[VerifiedBundle, ...]:
    return _verify_catalog(PROJECT_ROOT if project_root is None else project_root)
