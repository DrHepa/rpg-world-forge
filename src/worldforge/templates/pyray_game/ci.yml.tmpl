name: game-ci

on:
  push:
  pull_request:

permissions:
  contents: read

jobs:
  headless:
    name: Headless (${{ matrix.os }}, Python ${{ matrix.python }})
    strategy:
      fail-fast: false
      matrix:
        os:
          - ubuntu-24.04
          - windows-2022
        python:
          - "3.11"
          - "3.12"
    runs-on: ${{ matrix.os }}
    steps:
      - name: Check out source
        uses: actions/checkout@11d5960a326750d5838078e36cf38b85af677262 # releases/v4 security backport
        with:
          persist-credentials: false
      - name: Set up Python
        uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5.6.0
        with:
          python-version: ${{ matrix.python }}
          cache: pip
          cache-dependency-path: requirements.lock
      - run: python scripts/verify_game.py
      - run: python -m pip install --requirement requirements.lock
      - run: python -m pip install --no-build-isolation --no-deps -e .
      - run: python -m pip check
      - run: python scripts/verify_game.py
      - run: ruff check src tests scripts run_game.py
      - run: ruff format --check src tests scripts run_game.py
      - run: python -m unittest discover -s tests

  native-smoke:
    name: Native smoke (${{ matrix.os }})
    strategy:
      fail-fast: false
      matrix:
        os:
          - ubuntu-24.04
          - windows-2022
    runs-on: ${{ matrix.os }}
    steps:
      - name: Check out source
        uses: actions/checkout@11d5960a326750d5838078e36cf38b85af677262 # releases/v4 security backport
        with:
          persist-credentials: false
      - name: Set up Python
        uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5.6.0
        with:
          python-version: "3.12"
          cache: pip
          cache-dependency-path: requirements.lock
      - run: python scripts/verify_game.py
      - run: python -m pip install --requirement requirements.lock
      - run: python -m pip install --no-build-isolation --no-deps -e .
      - name: Install virtual display
        if: runner.os == 'Linux'
        run: |
          sudo apt-get update
          sudo apt-get install --yes --no-install-recommends xvfb xauth
      - name: Hidden-window smoke (Linux)
        if: runner.os == 'Linux'
        run: xvfb-run -a python scripts/native_smoke.py --width 640 --height 360
      - name: Hidden-window smoke (Windows)
        if: runner.os == 'Windows'
        run: python scripts/native_smoke.py --width 640 --height 360
