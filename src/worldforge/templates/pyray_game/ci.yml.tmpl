name: game-ci

on:
  push:
  pull_request:

permissions:
  contents: read

jobs:
  headless:
    strategy:
      fail-fast: false
      matrix:
        os: [ubuntu-latest, windows-latest, macos-latest]
        profile:
          - {width: 640, height: 360}
          - {width: 1280, height: 720}
        python: ["3.11", "3.12"]
    runs-on: ${{ matrix.os }}
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: ${{ matrix.python }}
          cache: pip
      - run: python scripts/verify_game.py
      - run: python -m pip install --requirement requirements.lock
      - run: python -m pip install --no-build-isolation --no-deps -e .
      - run: python scripts/verify_game.py
      - run: ruff check src tests scripts run_game.py
      - run: ruff format --check src tests scripts run_game.py
      - run: python -m unittest discover -s tests

  native-smoke:
    strategy:
      fail-fast: false
      matrix:
        os: [ubuntu-latest, windows-latest, macos-latest]
        profile:
          - {width: 640, height: 360}
          - {width: 1280, height: 720}
    runs-on: ${{ matrix.os }}
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip
      - run: python scripts/verify_game.py
      - run: python -m pip install --requirement requirements.lock
      - run: python -m pip install --no-build-isolation --no-deps -e .
      - name: Hidden-window smoke (Linux)
        if: runner.os == 'Linux'
        run: >-
          xvfb-run -a python scripts/native_smoke.py
          --width ${{ matrix.profile.width }} --height ${{ matrix.profile.height }}
      - name: Hidden-window smoke (Windows/macOS)
        if: runner.os != 'Linux'
        run: >-
          python scripts/native_smoke.py
          --width ${{ matrix.profile.width }} --height ${{ matrix.profile.height }}
