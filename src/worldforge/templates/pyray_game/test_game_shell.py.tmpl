    def test_replay_slots_round_trip_outside_the_game_tree(self) -> None:
        releases = load_catalog(PROJECT_ROOT)
        if not releases:
            self.skipTest("an installed release is required for replay execution")
        release = releases[0]
        clean_environment = {key: value for key, value in os.environ.items() if key != "PYTHONPATH"}
        with tempfile.TemporaryDirectory() as temporary:
            user_data = Path(temporary) / "user-data"
            base = [
                sys.executable,
                "-S",
                str(PROJECT_ROOT / "run_game.py"),
                "--world",
                release.world_id,
                "--release",
                release.release_id,
                "--user-data",
                str(user_data),
            ]
            recorded = subprocess.run(
                [*base, "--headless-ticks", "3", "--record-replay-slot", "smoke"],
                cwd=Path(temporary),
                env=clean_environment,
                capture_output=True,
                text=True,
                check=False,
            )
            self.assertEqual(recorded.returncode, 0, recorded.stdout + recorded.stderr)
            replay = user_data / "replays" / release.world_id / release.release_id / "smoke.json"
            self.assertTrue(replay.is_file())
            played = subprocess.run(
                [*base, "--replay-slot", "smoke"],
                cwd=Path(temporary),
                env=clean_environment,
                capture_output=True,
                text=True,
                check=False,
            )
            self.assertEqual(played.returncode, 0, played.stdout + played.stderr)
            self.assertIn("replay_actions=3 tick=3", played.stdout)
            self.assertEqual(_output_digest(recorded.stdout), _output_digest(played.stdout))

            original = replay.read_bytes()
            corrupted = json.loads(original)
            corrupted["final_state_digest"] = "0" * 64
            try:
                replay.write_bytes(
                    (json.dumps(corrupted, indent=2, sort_keys=True) + "\n").encode("utf-8")
                )
                rejected = subprocess.run(
                    [*base, "--replay-slot", "smoke"],
                    cwd=Path(temporary),
                    env=clean_environment,
                    capture_output=True,
                    text=True,
                    check=False,
                )
            finally:
                replay.write_bytes(original)
            self.assertNotEqual(rejected.returncode, 0)
            self.assertEqual("", rejected.stdout)
            self.assertIn("Replay result differs", rejected.stderr)
            self.assertNotIn("Traceback", rejected.stderr)
            restored = subprocess.run(
                [*base, "--replay-slot", "smoke"],
                cwd=Path(temporary),
                env=clean_environment,
                capture_output=True,
                text=True,
                check=False,
            )
            self.assertEqual(restored.returncode, 0, restored.stdout + restored.stderr)
            self.assertEqual(_output_digest(recorded.stdout), _output_digest(restored.stdout))

            zero_recorded = subprocess.run(
                [*base, "--headless-ticks", "0", "--record-replay-slot", "zero"],
                cwd=Path(temporary),
                env=clean_environment,
                capture_output=True,
                text=True,
                check=False,
            )
            self.assertEqual(
                zero_recorded.returncode,
                0,
                zero_recorded.stdout + zero_recorded.stderr,
            )
            zero_played = subprocess.run(
                [*base, "--replay-slot", "zero"],
                cwd=Path(temporary),
                env=clean_environment,
                capture_output=True,
                text=True,
                check=False,
            )
            self.assertEqual(
                zero_played.returncode,
                0,
                zero_played.stdout + zero_played.stderr,
            )
            self.assertIn("replay_actions=0 tick=0", zero_played.stdout)
            self.assertEqual(
                _output_digest(zero_recorded.stdout),
                _output_digest(zero_played.stdout),
            )

            forbidden_user_data = PROJECT_ROOT / "forbidden-user-data"
            self.assertFalse(forbidden_user_data.exists())
            forbidden = subprocess.run(
                [
                    sys.executable,
                    "-S",
                    str(PROJECT_ROOT / "run_game.py"),
                    "--world",
                    release.world_id,
                    "--release",
                    release.release_id,
                    "--user-data",
                    str(forbidden_user_data),
                    "--headless-ticks",
                    "0",
                    "--record-replay-slot",
                    "forbidden",
                ],
                cwd=Path(temporary),
                env=clean_environment,
                capture_output=True,
                text=True,
                check=False,
            )
            self.assertNotEqual(forbidden.returncode, 0)
            self.assertIn("outside the installed game tree", forbidden.stderr)
            self.assertNotIn("Traceback", forbidden.stderr)
            self.assertFalse(forbidden_user_data.exists())
        self.assertFalse((PROJECT_ROOT / "replays").exists())

    def test_replay_cli_rejects_unsafe_slots_and_conflicts(self) -> None:
        cases = (
            ("--record-replay-slot", "../unsafe"),
            ("--record-replay-slot", "record", "--load-slot", "save"),
            ("--replay-slot", "replay", "--quick-save-slot", "quick"),
            ("--replay-slot", "replay", "--record-replay-slot", "record"),
        )
        for arguments in cases:
            with self.subTest(arguments=arguments):
                result = subprocess.run(
                    [sys.executable, "-S", "-m", "game", *arguments],
                    cwd=PROJECT_ROOT,
                    env=self._environment(),
                    capture_output=True,
                    text=True,
                    check=False,
                )
                self.assertEqual(result.returncode, 2, result.stdout + result.stderr)
                self.assertIn("error:", result.stderr)
                self.assertNotIn("Traceback", result.stderr)

