    def test_platform_user_data_defaults_are_absolute_and_fail_safe(self) -> None:
        with tempfile.TemporaryDirectory() as temporary:
            root = Path(temporary)
            home = root / "home"
            linux_root = root / "xdg-data"
            windows_root = root / "local-app-data"
            selected_cases = (
                ("linux", "XDG_DATA_HOME", linux_root),
                ("win32", "LOCALAPPDATA", windows_root),
            )
            for platform, variable, selected in selected_cases:
                with (
                    self.subTest(platform=platform, selected=selected),
                    patch.object(game_main.sys, "platform", platform),
                    patch.object(game_main.Path, "home", return_value=home),
                    patch.dict(os.environ, {variable: str(selected)}, clear=True),
                ):
                    actual = game_main._default_user_data_root()
                    self.assertEqual((selected / GAME_ID).resolve(), actual)
                    self.assertTrue(actual.is_absolute())

            fallback_cases = (
                ("linux", "XDG_DATA_HOME", Path(".local/share")),
                ("win32", "LOCALAPPDATA", Path("AppData/Local")),
            )
            for platform, variable, suffix in fallback_cases:
                for value in (None, "", "relative/data"):
                    environment = {} if value is None else {variable: value}
                    with (
                        self.subTest(platform=platform, value=value),
                        patch.object(game_main.sys, "platform", platform),
                        patch.object(game_main.Path, "home", return_value=home),
                        patch.dict(os.environ, environment, clear=True),
                    ):
                        actual = game_main._default_user_data_root()
                        self.assertEqual((home / suffix / GAME_ID).resolve(), actual)
                        self.assertTrue(actual.is_absolute())

    def test_catalog_shell_starts_headlessly(self) -> None:
        releases = load_catalog(PROJECT_ROOT)
        arguments = [sys.executable, "-m", "game"]
        if releases:
            release = releases[0]
            arguments.extend(
                [
                    "--world",
                    release.world_id,
                    "--release",
                    release.release_id,
                    "--headless-ticks",
                    "0",
                ]
            )
            expected = f"world={release.world_id} release={release.release_id} tick=0"
        else:
            arguments.extend(["--headless-ticks", "0"])
            expected = "status=empty_catalog shell=ready"
        result = subprocess.run(
            arguments,
            cwd=PROJECT_ROOT,
            env=self._environment(),
            capture_output=True,
            text=True,
            check=False,
        )
        self.assertEqual(result.returncode, 0, result.stdout + result.stderr)
        self.assertIn(expected, result.stdout)

