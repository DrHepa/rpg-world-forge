from __future__ import annotations

import hashlib
import importlib.util
import json
import os
import subprocess
import sys
import tempfile
import unittest
import zipfile
from pathlib import Path
from unittest.mock import patch

from game import GAME_ID, GAME_TITLE
from game.catalog import PROJECT_ROOT, load_catalog
from isoworld.content.models import RUNTIME_API_VERSION, SUPPORTED_RUNTIME_FEATURES


class GameShellTests(unittest.TestCase):
    def _environment(self) -> dict[str, str]:
        environment = os.environ.copy()
        environment["PYTHONPATH"] = str(PROJECT_ROOT / "src")
        return environment

    def test_identity_and_runtime_contract_are_explicit(self) -> None:
        self.assertEqual(GAME_ID, "__GAME_ID__")
        self.assertEqual(GAME_TITLE, __GAME_TITLE_PY__)
        self.assertRegex(RUNTIME_API_VERSION, r"^\d+\.\d+\.\d+$")
        self.assertIsInstance(SUPPORTED_RUNTIME_FEATURES, frozenset)

    def test_catalog_shell_starts_headlessly(self) -> None:
        releases = load_catalog(PROJECT_ROOT)
        arguments = [sys.executable, "-m", "game"]
        if releases:
            release = releases[0]
            arguments.extend(
                [
                    "--world",
                    release.world_id,
                    "--release",
                    release.release_id,
                    "--headless-ticks",
                    "0",
                ]
            )
            expected = f"world={release.world_id} release={release.release_id} tick=0"
        else:
            arguments.extend(["--headless-ticks", "0"])
            expected = "status=empty_catalog shell=ready"
        result = subprocess.run(
            arguments,
            cwd=PROJECT_ROOT,
            env=self._environment(),
            capture_output=True,
            text=True,
            check=False,
        )
        self.assertEqual(result.returncode, 0, result.stdout + result.stderr)
        self.assertIn(expected, result.stdout)

    def test_verifier_is_independent_of_working_directory(self) -> None:
        with tempfile.TemporaryDirectory() as temporary:
            result = subprocess.run(
                [sys.executable, str(PROJECT_ROOT / "scripts/verify_game.py")],
                cwd=temporary,
                env=self._environment(),
                capture_output=True,
                text=True,
                check=False,
            )
        self.assertEqual(result.returncode, 0, result.stdout + result.stderr)
        self.assertIn("verification=pass", result.stdout)

    def test_runtime_does_not_require_forge_on_pythonpath(self) -> None:
        result = subprocess.run(
            [
                sys.executable,
                "-S",
                "-c",
                "import importlib.util; assert importlib.util.find_spec('worldforge') is None",
            ],
            cwd=PROJECT_ROOT,
            env=self._environment(),
            capture_output=True,
            text=True,
            check=False,
        )
        self.assertEqual(result.returncode, 0, result.stdout + result.stderr)

    def test_portable_package_has_a_deterministic_manifest(self) -> None:
        with tempfile.TemporaryDirectory() as temporary:
            output = Path(temporary) / "game-a.zip"
            result = subprocess.run(
                [
                    sys.executable,
                    str(PROJECT_ROOT / "scripts/package_game.py"),
                    "--output",
                    str(output),
                ],
                cwd=temporary,
                env=self._environment(),
                capture_output=True,
                text=True,
                check=False,
            )
            self.assertEqual(result.returncode, 0, result.stdout + result.stderr)
            with zipfile.ZipFile(output) as archive:
                names = archive.namelist()
                self.assertEqual(names, sorted(names))
                manifest = json.loads(archive.read("PACKAGE-MANIFEST.json"))
                extracted = Path(temporary) / "extracted"
                archive.extractall(extracted)
            releases = load_catalog(PROJECT_ROOT)
            launch_arguments = [sys.executable, str(extracted / "run_game.py")]
            if releases:
                release = releases[0]
                launch_arguments.extend(
                    ["--world", release.world_id, "--release", release.release_id]
                )
            launch_arguments.extend(["--headless-ticks", "0"])
            launched = subprocess.run(
                launch_arguments,
                cwd=extracted,
                env={key: value for key, value in os.environ.items() if key != "PYTHONPATH"},
                capture_output=True,
                text=True,
                check=False,
            )
            self.assertEqual(launched.returncode, 0, launched.stdout + launched.stderr)
            expected = "tick=0" if releases else "status=empty_catalog shell=ready"
            self.assertIn(expected, launched.stdout)
            second_output = Path(temporary) / "game-b.zip"
            second = subprocess.run(
                [
                    sys.executable,
                    str(PROJECT_ROOT / "scripts/package_game.py"),
                    "--output",
                    str(second_output),
                ],
                cwd=temporary,
                env=self._environment(),
                capture_output=True,
                text=True,
                check=False,
            )
            self.assertEqual(second.returncode, 0, second.stdout + second.stderr)
            self.assertEqual(
                hashlib.sha256(output.read_bytes()).hexdigest(),
                hashlib.sha256(second_output.read_bytes()).hexdigest(),
            )
            repeated = subprocess.run(
                [
                    sys.executable,
                    str(PROJECT_ROOT / "scripts/package_game.py"),
                    "--output",
                    str(output),
                ],
                cwd=temporary,
                env=self._environment(),
                capture_output=True,
                text=True,
                check=False,
            )
            self.assertNotEqual(repeated.returncode, 0)
        self.assertEqual(manifest["format"], "isoworld.game_package")
        self.assertEqual(manifest["game_id"], GAME_ID)
        self.assertFalse(any("AGENTS" in name or ".agents/" in name for name in names))

    def test_packager_respects_the_shared_game_mutation_lock(self) -> None:
        with tempfile.TemporaryDirectory() as temporary:
            lock = PROJECT_ROOT / ".isoworld-mutation.lock"
            lock.write_text("owned by another operation\n", encoding="utf-8")
            output = Path(temporary) / "must-not-exist.zip"
            try:
                result = subprocess.run(
                    [
                        sys.executable,
                        str(PROJECT_ROOT / "scripts/package_game.py"),
                        "--output",
                        str(output),
                    ],
                    cwd=temporary,
                    env=self._environment(),
                    capture_output=True,
                    text=True,
                    check=False,
                )
                self.assertNotEqual(result.returncode, 0)
                self.assertIn("already in progress", result.stderr)
                self.assertEqual(
                    "owned by another operation\n",
                    lock.read_text(encoding="utf-8"),
                )
                self.assertFalse(output.exists())
            finally:
                lock.unlink(missing_ok=True)

    def test_packager_archives_one_private_snapshot_under_source_mutation(self) -> None:
        with tempfile.TemporaryDirectory() as temporary:
            source = PROJECT_ROOT / "src/game/package_race_probe.py"
            source.write_text("VALUE = 'before'\n", encoding="utf-8")
            output = Path(temporary) / "snapshot.zip"
            specification = importlib.util.spec_from_file_location(
                "game_package_script",
                PROJECT_ROOT / "scripts/package_game.py",
            )
            self.assertIsNotNone(specification)
            self.assertIsNotNone(specification.loader)
            module = importlib.util.module_from_spec(specification)
            specification.loader.exec_module(module)
            original_write = module._write_file
            mutated = False

            def mutate_source_then_write(archive, relative, snapshot_path):
                nonlocal mutated
                if not mutated:
                    source.write_text("VALUE = 'after'\n", encoding="utf-8")
                    mutated = True
                return original_write(archive, relative, snapshot_path)

            try:
                with patch.object(module, "_write_file", side_effect=mutate_source_then_write):
                    module.build_package(output)
                with zipfile.ZipFile(output) as archive:
                    manifest = json.loads(archive.read("PACKAGE-MANIFEST.json"))
                    relative = "src/game/package_race_probe.py"
                    archived = archive.read(relative)
                    record = next(item for item in manifest["files"] if item["path"] == relative)
                self.assertEqual(record["size"], len(archived))
                self.assertEqual(record["sha256"], hashlib.sha256(archived).hexdigest())
                self.assertEqual(b"VALUE = 'before'\n", archived)
            finally:
                source.unlink(missing_ok=True)

    def test_packager_reverifies_identity_inside_the_private_snapshot(self) -> None:
        with tempfile.TemporaryDirectory() as temporary:
            identity_path = PROJECT_ROOT / "src/game/__init__.py"
            project_path = PROJECT_ROOT / "pyproject.toml"
            identity_bytes = identity_path.read_bytes()
            project_bytes = project_path.read_bytes()
            output = Path(temporary) / "identity-snapshot.zip"
            specification = importlib.util.spec_from_file_location(
                "game_identity_snapshot_package_script",
                PROJECT_ROOT / "scripts/package_game.py",
            )
            self.assertIsNotNone(specification)
            self.assertIsNotNone(specification.loader)
            module = importlib.util.module_from_spec(specification)
            specification.loader.exec_module(module)
            original_snapshot = module._snapshot_inputs
            changed_game_id = "snapshot_identity"
            mutated = False

            def mutate_identity_then_snapshot(inputs, snapshot_root):
                nonlocal mutated
                if not mutated:
                    identity_path.write_text(
                        identity_bytes.decode("utf-8").replace(
                            f'GAME_ID = "{GAME_ID}"',
                            f'GAME_ID = "{changed_game_id}"',
                        ),
                        encoding="utf-8",
                    )
                    project_path.write_text(
                        project_bytes.decode("utf-8").replace(
                            f'name = "{GAME_ID.replace("_", "-")}"',
                            f'name = "{changed_game_id.replace("_", "-")}"',
                        ),
                        encoding="utf-8",
                    )
                    project_path.write_text(
                        project_path.read_text(encoding="utf-8").replace(
                            f'\n{GAME_ID.replace("_", "-")} = "game.__main__:main"',
                            f'\n{changed_game_id.replace("_", "-")} = "game.__main__:main"',
                        ),
                        encoding="utf-8",
                    )
                    mutated = True
                return original_snapshot(inputs, snapshot_root)

            try:
                with patch.object(
                    module,
                    "_snapshot_inputs",
                    side_effect=mutate_identity_then_snapshot,
                ):
                    module.build_package(output)
                with zipfile.ZipFile(output) as archive:
                    manifest = json.loads(archive.read("PACKAGE-MANIFEST.json"))
                    archived_identity = archive.read("src/game/__init__.py")
                self.assertEqual(changed_game_id, manifest["game_id"])
                self.assertIn(
                    f'GAME_ID = "{changed_game_id}"'.encode(),
                    archived_identity,
                )
            finally:
                identity_path.write_bytes(identity_bytes)
                project_path.write_bytes(project_bytes)


if __name__ == "__main__":
    unittest.main()
