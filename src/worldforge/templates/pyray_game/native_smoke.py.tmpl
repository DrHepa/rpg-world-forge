from __future__ import annotations

import argparse
import json
import os
import platform
from pathlib import Path


def main() -> int:
    parser = argparse.ArgumentParser(description="Exercise one native pyray platform profile")
    parser.add_argument("--width", type=int, default=640)
    parser.add_argument("--height", type=int, default=360)
    parser.add_argument("--audio", choices=("off", "optional", "required"), default="off")
    args = parser.parse_args()
    if args.width < 64 or args.height < 64:
        raise SystemExit("native smoke dimensions must be at least 64x64")

    import pyray as pr

    project_root = Path(__file__).resolve().parents[1]
    platform_lock = json.loads((project_root / "platform.lock.json").read_text(encoding="utf-8"))
    pr.set_config_flags(pr.FLAG_WINDOW_HIDDEN | pr.FLAG_WINDOW_RESIZABLE)
    pr.init_window(args.width, args.height, "native smoke")
    audio_initialized = False
    audio_ready = False
    try:
        if not pr.is_window_ready():
            raise RuntimeError("raylib window did not initialize")
        if args.audio != "off":
            pr.init_audio_device()
            audio_initialized = True
            audio_ready = pr.is_audio_device_ready()
            if args.audio == "required" and not audio_ready:
                raise RuntimeError("required raylib audio device did not initialize")
        dpi = pr.get_window_scale_dpi()
        mouse = pr.get_mouse_position()
        input_probe = {
            "gamepad_0_available": bool(pr.is_gamepad_available(0)),
            "mouse_x": float(mouse.x),
            "mouse_y": float(mouse.y),
        }
        pr.begin_drawing()
        pr.clear_background(pr.BLACK)
        pr.draw_rectangle(8, 8, 32, 16, pr.MAGENTA)
        pr.end_drawing()
    finally:
        if audio_initialized:
            pr.close_audio_device()
        pr.close_window()
    result = {
        "native_smoke": "pass",
        "ci": bool(os.environ.get("CI")),
        "os": platform.system(),
        "architecture": platform.machine(),
        "backend": platform_lock["backend"],
        "binding": (f"{platform_lock['binding_distribution']}=={platform_lock['binding_version']}"),
        "native_api": platform_lock["native_api_version"],
        "width": args.width,
        "height": args.height,
        "dpi_scale": [float(dpi.x), float(dpi.y)],
        "audio_mode": args.audio,
        "audio_ready": audio_ready,
        "input_probe": input_probe,
    }
    print(json.dumps(result, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
