{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-world-forge.local/schemas/studio-shell-package-manifest.schema.json",
  "additionalProperties": false,
  "allOf": [
    {
      "properties": {
        "open_blocker_codes": {
          "const": [
            "codex_ripgrep_static_dependency_notice_sbom_incomplete",
            "linux_bwrap_lgpl_corresponding_source_relink_build_materials_incomplete",
            "linux_bwrap_musl_provenance_incomplete",
            "pbs_zlib_ng_license_incomplete",
            "linux_berkeley_db_dbm_route_unresolved",
            "windows_vc_runtime_redistribution_authority_unresolved",
            "github_attestation_trust_root_rfc3161_verification_pending"
          ]
        }
      }
    }
  ],
  "properties": {
    "app_asar": {
      "additionalProperties": false,
      "properties": {
        "entries": {
          "maximum": 16384,
          "minimum": 4,
          "type": "integer"
        },
        "entries_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "main": {
          "const": "dist-electron/main/index.cjs"
        },
        "path": {
          "const": "resources/app.asar"
        },
        "preload": {
          "const": "dist-electron/preload/index.cjs"
        },
        "renderer": {
          "const": "dist-renderer/index.html"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size": {
          "maximum": 1073741824,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "entries",
        "entries_sha256",
        "main",
        "path",
        "preload",
        "renderer",
        "sha256",
        "size"
      ],
      "type": "object"
    },
    "bundled_runtimes": {
      "additionalProperties": false,
      "properties": {
        "codex": {
          "const": false
        },
        "python": {
          "const": false
        }
      },
      "required": [
        "codex",
        "python"
      ],
      "type": "object"
    },
    "electron": {
      "additionalProperties": false,
      "properties": {
        "executable": {
          "$ref": "#/$defs/portablePath"
        },
        "fuses": {
          "additionalProperties": false,
          "properties": {
            "enable_cookie_encryption": {
              "const": true
            },
            "enable_embedded_asar_integrity_validation": {
              "const": true
            },
            "enable_node_cli_inspect_arguments": {
              "const": false
            },
            "enable_node_options_environment_variable": {
              "const": false
            },
            "grant_file_protocol_extra_privileges": {
              "const": false
            },
            "only_load_app_from_asar": {
              "const": true
            },
            "run_as_node": {
              "const": false
            }
          },
          "required": [
            "enable_cookie_encryption",
            "enable_embedded_asar_integrity_validation",
            "enable_node_cli_inspect_arguments",
            "enable_node_options_environment_variable",
            "grant_file_protocol_extra_privileges",
            "only_load_app_from_asar",
            "run_as_node"
          ],
          "type": "object"
        }
      },
      "required": [
        "executable",
        "fuses"
      ],
      "type": "object"
    },
    "format": {
      "const": "rpg-world-forge.studio_shell_package_manifest"
    },
    "format_version": {
      "const": 1,
      "type": "integer"
    },
    "inventory": {
      "items": {
        "$ref": "#/$defs/inventoryEntry"
      },
      "maxItems": 16384,
      "minItems": 1,
      "type": "array"
    },
    "open_blocker_codes": {
      "items": {
        "pattern": "^[a-z][a-z0-9_]{2,127}$",
        "type": "string"
      },
      "maxItems": 64,
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "package_kind": {
      "const": "shell_only"
    },
    "redistribution_status": {
      "const": "blocked"
    },
    "release_ready": {
      "const": false
    },
    "resources": {
      "additionalProperties": false,
      "properties": {
        "codex_protocol": {
          "additionalProperties": false,
          "properties": {
            "bytes": {
              "maximum": 67108864,
              "minimum": 1,
              "type": "integer"
            },
            "files": {
              "maximum": 4096,
              "minimum": 3,
              "type": "integer"
            },
            "inventory_sha256": {
              "$ref": "#/$defs/sha256"
            },
            "manifest": {
              "$ref": "#/$defs/identity"
            },
            "root": {
              "const": "resources/protocol/codex-app-server-0.144.6"
            }
          },
          "required": [
            "bytes",
            "files",
            "inventory_sha256",
            "manifest",
            "root"
          ],
          "type": "object"
        },
        "runtime_manifest": {
          "$ref": "#/$defs/identity"
        },
        "runtime_sources": {
          "$ref": "#/$defs/identity"
        },
        "schemas": {
          "items": {
            "$ref": "#/$defs/identity"
          },
          "maxItems": 3,
          "minItems": 3,
          "type": "array"
        }
      },
      "required": [
        "codex_protocol",
        "runtime_manifest",
        "runtime_sources",
        "schemas"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "https://rpg-world-forge.local/schemas/studio-shell-package-manifest.schema.json"
    },
    "target_id": {
      "enum": [
        "linux-x64",
        "win32-x64"
      ]
    }
  },
  "required": [
    "app_asar",
    "bundled_runtimes",
    "electron",
    "format",
    "format_version",
    "inventory",
    "open_blocker_codes",
    "package_kind",
    "redistribution_status",
    "release_ready",
    "resources",
    "schema_id",
    "target_id"
  ],
  "title": "RPG World Forge Studio shell package manifest",
  "type": "object",
  "$defs": {
    "identity": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/portablePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size": {
          "maximum": 1073741824,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "path",
        "sha256",
        "size"
      ],
      "type": "object"
    },
    "inventoryEntry": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/portablePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size": {
          "maximum": 1073741824,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "path",
        "sha256",
        "size"
      ],
      "type": "object"
    },
    "portablePath": {
      "maxLength": 1024,
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?/)(?!.*(?:^|/)\\.\\.?$)[\\u0020-\\u007e]+$",
      "type": "string"
    },
    "sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  }
}
